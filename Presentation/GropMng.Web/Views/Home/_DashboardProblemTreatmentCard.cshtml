@model GropMng.Web.Models.Dashboard.DashboardActionModel
@using GropMng.Web.Models.Dashboard

@{
    var plantDisplayName = string.IsNullOrWhiteSpace(Model.Nickname) ? Model.PlantName : $"{Model.PlantName} ({Model.Nickname})";
    var overdueDays = Model.DueStatus == DashboardDueStatus.Overdue
        ? DateOnly.FromDateTime(DateTime.UtcNow).DayNumber - Model.DueDate.DayNumber
        : 0;
    var isCountable = Model.DueStatus != DashboardDueStatus.Upcoming;
    var locationDisplay = string.IsNullOrWhiteSpace(Model.GardenSpotName) ? Model.LocationName : Model.GardenSpotName;
}

<div class="col mb-2"
    data-dashboard-action-item="true"
    data-skip-key="@("problem:" + Model.PlantInstanceId)"
    data-spot-id="@Model.GardenSpotId"
    data-due-status="@Model.DueStatus.ToString().ToLowerInvariant()"
    data-bulk-eligible="false">
    <div class="card h-100 dashboard-action-card">
        <div class="card-header">
            <div class="card-action-title">@(Model.Nickname ?? string.Empty)</div>
            <div class="fs-4">@Model.PlantName</div>
        </div>

        @if (!string.IsNullOrEmpty(Model.PlantMainImageUrl)) {
            <img src="@Model.PlantMainImageUrl" alt="@Model.PlantName" class="card-img-top"/>
        }
        else {
            <div class="dashboard-action-card__fallback">
                <svg class="dashboard-action-card__icon" aria-hidden="true" focusable="false">
                    <use href="#gm-icon-leaf"></use>
                </svg>
            </div>
        }

        <div class="card-body">

           <h3 class="fw-normal mb-4">@locationDisplay</h3>

           <!-- Action Info -->
           <div class="d-flex gap-2 border-top pb-3 pt-3">
               <!-- Ημερομηνία -->
               <div class="d-flex align-items-start gap-2 flex-fill">
                   <svg aria-hidden="true" class="icon flex-shrink-0 mt-1">
                       <use href="#gm-icon-otl_bug" />
                   </svg>
                   <div>
                       <div class="fw-bold" style="font-size:13px;">@Model.DueDate.ToString("yyyy-MM-dd")</div>
                       <div style="font-size: 12px; color: #e8a832;">
                           @if (Model.DueStatus == DashboardDueStatus.Today) {
                               @T("dashboard.owner.status.today")
                           }
                           else if (Model.DueStatus == DashboardDueStatus.Overdue) {
                               @overdueDays
                               @T("dashboard.owner.daysago")
                           }
                           else {
                               @string.Format(T("dashboard.owner.group.inxdays").ToString(), Model.DeltaDaysFromToday)
                           }
                       </div>
                   </div>
               </div>

               <!-- Ενέργεια -->
               <div class="d-flex align-items-start gap-2 flex-fill">
                   <svg aria-hidden="true" class="icon flex-shrink-0 mt-1" style="color:#e8a832;">
                       <use href="#gm-icon-alarm-check" />
                   </svg>
                   <div>
                       <div class="fw-bold" style="font-size:13px;">@(Model.ScheduleActionName ?? "—")</div>
                       <div style="font-size:12px; color:#e8a832;">
                           @if (!string.IsNullOrWhiteSpace(Model.DosageNotes))
                           {
                               <span class="qty-label-text">@Model.DosageNotes.TruncateAtWord(25)</span>
                           }
                           else
                           {
                               @T("dashboard.owner.tab.diseases")
                           }
                       </div>
                   </div>
               </div>
           </div>
           <!--/ Action Info -->

           <!-- Actions -->
           <div class="d-flex justify-content-between border-top p-3" style="border-color:rgba(255,255,255,.1)!important;">
               <button type="button"
                       class="btn btn-label-primary p-0 btn-action-done"
                       data-url=""
                       data-plant-instance-id="@Model.PlantInstanceId"
                       data-action-type="problem-treatment"
                       data-due-status="@Model.DueStatus.ToString().ToLowerInvariant()"
                       data-due-date="@Model.DueDate.ToString("yyyy-MM-dd")"
                       data-counter="@(isCountable ? "diseases-count" : "")"
                       data-label-done="@T("common.details")"
                       disabled
                       aria-label="@T("common.details")"
                       title="@T("common.details")">
                   <svg class="icon2" aria-hidden="true" focusable="false">
                       <use href="#gm-icon-info"></use>
                   </svg>
               </button>
               <a href="@Url.Action("Edit", "PlantInstance", new { id = Model.PlantInstanceId })"
                  class="btn btn-label-primary p-0"
                  aria-label="@T("common.details")"
                  title="@T("common.details")">
                   <svg class="icon2" aria-hidden="true" focusable="false">
                       <use href="#gm-icon-info"></use>
                   </svg>
               </a>
           </div>
           <!--/ Actions -->

        </div>
    </div>
</div>