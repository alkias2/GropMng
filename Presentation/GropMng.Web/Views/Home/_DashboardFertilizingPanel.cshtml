@model GropMng.Web.Models.Dashboard.DashboardFertilizingTabModel
@using GropMng.Web.Models.Dashboard

@if (!Model.TodayOverdueActions.Any())
{
    <div class="p-4" id="actions-empty-msg">
        <p class="text-muted mb-0">@T("dashboard.owner.todayactions.empty")</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5" data-dashboard-group="today-overdue">
        @foreach (var action in Model.TodayOverdueActions)
        {
            @await Html.PartialAsync("_DashboardActionCard", action)
        }
    </div>
}

@if (Model.UpcomingActionGroups.Any())
{
    <div class="upcoming-section d-none" data-section="fertilizing">
        @foreach (var group in Model.UpcomingActionGroups)
        {
            <div class="d-flex align-items-center justify-content-between mt-4 mb-2">
                <h6 class="mb-0">@group.GroupLabel</h6>
                <small class="text-muted">@group.Actions.Count</small>
            </div>
            <div class="row" data-dashboard-group="upcoming" data-group-days="@group.DeltaDaysFromToday">
                @foreach (var action in group.Actions)
                {
                    @await Html.PartialAsync("_DashboardActionCard", action)
                }
            </div>
        }
    </div>
}

