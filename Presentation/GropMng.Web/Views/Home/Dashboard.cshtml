@model GropMng.Web.Models.Dashboard.OwnerDashboardModel
@using GropMng.Web.Models.Dashboard
@{
    ViewData["Title"] = T("dashboard.owner.title").ToString();
    GropHtml.SetActiveMenuItemSystemName("Dashboard");
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-none" id="dashboard-anti-forgery-token">
        @Html.AntiForgeryToken()
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">@T("dashboard.owner.title")</h4>
            <p class="text-muted mb-0">@T("dashboard.owner.subtitle")</p>
        </div>
        <a href="@Url.Action("List", "PlantInstance")" class="btn btn-primary">
            <i class="bx bx-leaf me-1"></i>@T("dashboard.owner.cta.myplants")
        </a>
    </div>

    <!-- Section selector -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center gap-4">

                <button type="button" class="dashboard-section-btn active" data-section="watering">
                    <div class="d-flex align-items-center gap-3">
                        <span class="bg-label-info p-2 rounded">
                            <i class="bx bx-droplet bx-sm"></i>
                        </span>
                        <div class="content-right">
                            <p class="mb-0 text-muted">@T("dashboard.owner.tab.watering")</p>
                            <h4 class="text-info mb-0">@Model.WateringTab.Actions.Count</h4>
                        </div>
                    </div>
                </button>

                <button type="button" class="dashboard-section-btn" data-section="fertilizing">
                    <div class="d-flex align-items-center gap-3">
                        <span class="bg-label-success p-2 rounded">
                           @*  <i class="bx bx-flask bx-sm"></i> *@
                           <i class="bx bx-dialpad bx-sm"></i>
                        </span>
                        <div class="content-right">
                            <p class="mb-0 text-muted">@T("dashboard.owner.tab.fertilizing")</p>
                            <h4 class="text-success mb-0">@Model.FertilizingTab.Actions.Count</h4>
                        </div>
                    </div>
                </button>

                <button type="button" class="dashboard-section-btn" data-section="diseases">
                    <div class="d-flex align-items-center gap-3">
                        <span class="bg-label-danger p-2 rounded">
                            <i class="bx bx-bug bx-sm"></i>
                        </span>
                        <div class="content-right">
                            <p class="mb-0 text-muted">@T("dashboard.owner.tab.diseases")</p>
                            <h4 class="text-danger mb-0">@Model.DiseaseTab.ActiveCases.Count</h4>
                        </div>
                    </div>
                </button>

                <div class="d-flex align-items-center gap-3 ms-auto" id="dashboard-spot-filter-wrapper">
                    <span class="bg-label-secondary p-2 rounded">
                        <i class="bx bx-filter-alt bx-sm"></i>
                    </span>
                    <div class="content-right">
                        <p class="mb-0 text-muted">@T("dashboard.owner.filter.label")</p>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-link p-0 fw-semibold dropdown-toggle"
                                    type="button"
                                    id="dashboardSpotFilter"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                <span id="dashboardSpotFilterLabel">@T("dashboard.owner.filter.allspots")</span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end" id="dashboardSpotFilterMenu" aria-labelledby="dashboardSpotFilter">
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Panel content -->
    <div id="dashboard-panel-content">
        @await Html.PartialAsync("_DashboardWateringPanel", Model.WateringTab)
    </div>
</div>

<!-- Skip Action Modal -->
<div class="modal fade" id="skipActionModal" tabindex="-1" aria-labelledby="skipActionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="skipActionModalLabel">
                    <i class="bx bx-skip-next me-1"></i>@T("dashboard.owner.skip.title")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">@T("dashboard.owner.skip.prompt")</p>
                <p class="fw-semibold skip-plant-name mb-3"></p>
                <div class="d-grid gap-2">
                    <button type="button" id="btnSkipToday" class="btn btn-warning">
                        <i class="bx bx-calendar-x me-1"></i>@T("dashboard.owner.skip.today")
                    </button>
                    <button type="button" id="btnSkipNext" class="btn btn-outline-secondary">
                        <i class="bx bx-bell me-1"></i>@T("dashboard.owner.skip.next")
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">@T("common.cancel")</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js-custom/dashboard-section-loader.js"></script>
    <script src="~/js-custom/dashboard-action-log.js"></script>
}
