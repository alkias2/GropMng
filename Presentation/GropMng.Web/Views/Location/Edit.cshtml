@model GropMng.Web.Models.Garden.LocationModel

@{
    GropHtml.SetActiveMenuItemSystemName("Locations");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">@Model.Name</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-style1">
                <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">@T("common.dashboard")</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("List", "Location")">@T("mygarden.location.list.title")</a></li>
                <li class="breadcrumb-item active">@T("mygarden.location.edit.title")</li>
            </ol>
        </nav>
    </div>
    <form method="post" action="@Url.Action("Delete", "Location", new { id = Model.Id })" data-grop-confirm="@T("common.delete.confirm")">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger">
            <i class="bx bx-trash me-1"></i>@T("common.delete")
        </button>
    </form>
</div>

<!-- Location Form -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">@T("mygarden.location.edit.details")</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" asp-controller="Location" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label">@T("mygarden.location.field.name") <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="City" class="form-label">@T("mygarden.location.field.city") <span class="text-danger">*</span></label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Country" class="form-label">@T("mygarden.location.field.country")</label>
                    <input asp-for="Country" class="form-control" />
                    <span asp-validation-for="Country" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ClimateZone" class="form-label">@T("mygarden.location.field.climatezone")</label>
                    <input asp-for="ClimateZone" class="form-control" />
                    <span asp-validation-for="ClimateZone" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Latitude" class="form-label">@T("mygarden.location.field.latitude")</label>
                    <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
                    <span asp-validation-for="Latitude" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Longitude" class="form-label">@T("mygarden.location.field.longitude")</label>
                    <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
                    <span asp-validation-for="Longitude" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label">@T("common.notes")</label>
                    <textarea asp-for="Notes" class="form-control"></textarea>
                    <div class="grop-quill-editor" data-quill-mode="full" data-input-selector="#Notes"></div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@T("common.save")</button>
                <a href="@Url.Action("List", "Location")" class="btn btn-outline-secondary">@T("common.cancel")</a>
            </div>
        </form>
    </div>
</div>

<!-- Garden Spots -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@T("mygarden.gardenspot.list.title")</h5>
        <a href="@Url.Action("Create", "GardenSpot", new { locationId = Model.Id })" class="btn btn-sm btn-primary">
            <i class="bx bx-plus me-1"></i>@T("mygarden.gardenspot.add")
        </a>
    </div>
    <div class="card-body">
        @if (!Model.GardenSpots.Any())
        {
            <p class="text-muted mb-0">@T("mygarden.gardenspot.list.empty")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>@T("mygarden.gardenspot.field.name")</th>
                            <th>@T("mygarden.gardenspot.field.orientation")</th>
                            <th>@T("mygarden.gardenspot.field.covertype")</th>
                            <th>@T("mygarden.gardenspot.field.sunhours")</th>
                            <th class="text-end">@T("common.actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var spot in Model.GardenSpots)
                        {
                            <tr>
                                <td>@spot.Name</td>
                                <td>@(spot.OrientationDisplay ?? "—")</td>
                                <td>@(spot.CoverTypeDisplay ?? "—")</td>
                                <td>@(spot.SunHoursPerDay.HasValue ? $"{spot.SunHoursPerDay}h" : "—")</td>
                                <td class="text-end">
                                    <a href="@Url.Action("Edit", "GardenSpot", new { locationId = Model.Id, spotId = spot.Id })" class="btn btn-sm btn-icon btn-outline-primary" title="@T("common.edit")">
                                        <i class="bx bx-edit"></i>
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "GardenSpot", new { locationId = Model.Id, spotId = spot.Id })" class="d-inline" data-grop-confirm="@T("common.delete.confirm")">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-icon btn-outline-danger" title="@T("common.delete")">
                                            <i class="bx bx-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
