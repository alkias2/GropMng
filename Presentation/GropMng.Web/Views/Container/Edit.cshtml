@model GropMng.Web.Models.Garden.ContainerModel

@{
    GropHtml.SetActiveMenuItemSystemName("Containers");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">@Model.ContainerType.ToString()</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-style1">
                <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">@T("common.dashboard")</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("List", "Container")">@T("mygarden.container.list.title")</a></li>
                <li class="breadcrumb-item active">@T("mygarden.container.edit.title")</li>
            </ol>
        </nav>
    </div>
    @if (Model.PlantInstanceNickname != null)
    {
        <form method="post" action="@Url.Action("Delete", "Container", new { id = Model.Id })" data-grop-confirm="@T("common.delete.confirm")">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger" disabled title="@T("mygarden.container.inuse.warning")">
                <i class="bx bx-trash me-1"></i>@T("common.delete")
            </button>
        </form>
    }
    else
    {
        <form method="post" action="@Url.Action("Delete", "Container", new { id = Model.Id })" data-grop-confirm="@T("common.delete.confirm")">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                <i class="bx bx-trash me-1"></i>@T("common.delete")
            </button>
        </form>
    }
</div>

<div class="card">
    <div class="card-body">
        @if (Model.PlantInstanceNickname != null)
        {
            <div class="alert alert-info mb-3">
                <i class="bx bx-leaf me-1"></i>
                @T("mygarden.container.linked.plant"): <strong>@Model.PlantInstanceNickname</strong>
            </div>
        }

        <form asp-action="Edit" asp-controller="Container" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="ContainerType" class="form-label">@T("mygarden.container.field.type")</label>
                    <select asp-for="ContainerType" asp-items="Model.AvailableContainerTypes" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Material" class="form-label">@T("mygarden.container.field.material")</label>
                    <input asp-for="Material" class="form-control" />
                    <span asp-validation-for="Material" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Color" class="form-label">@T("mygarden.container.field.color")</label>
                    <input asp-for="Color" class="form-control" />
                    <span asp-validation-for="Color" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="BaseCircumferenceCm" class="form-label">@T("mygarden.container.field.base")</label>
                    <div class="input-group">
                        <input asp-for="BaseCircumferenceCm" class="form-control" type="number" step="0.1" min="0" />
                        <span class="input-group-text">cm</span>
                    </div>
                    <span asp-validation-for="BaseCircumferenceCm" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="RimCircumferenceCm" class="form-label">@T("mygarden.container.field.rim")</label>
                    <div class="input-group">
                        <input asp-for="RimCircumferenceCm" class="form-control" type="number" step="0.1" min="0" />
                        <span class="input-group-text">cm</span>
                    </div>
                    <span asp-validation-for="RimCircumferenceCm" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="HeightCm" class="form-label">@T("mygarden.container.field.height")</label>
                    <div class="input-group">
                        <input asp-for="HeightCm" class="form-control" type="number" step="0.1" min="0" />
                        <span class="input-group-text">cm</span>
                    </div>
                    <span asp-validation-for="HeightCm" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="LengthCm" class="form-label">@T("mygarden.container.field.length")</label>
                    <div class="input-group">
                        <input asp-for="LengthCm" class="form-control" type="number" step="0.1" min="0" />
                        <span class="input-group-text">cm</span>
                    </div>
                    <span asp-validation-for="LengthCm" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="WidthCm" class="form-label">@T("mygarden.container.field.width")</label>
                    <div class="input-group">
                        <input asp-for="WidthCm" class="form-control" type="number" step="0.1" min="0" />
                        <span class="input-group-text">cm</span>
                    </div>
                    <span asp-validation-for="WidthCm" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="VolumeL" class="form-label">@T("mygarden.container.field.volume")</label>
                    <div class="input-group">
                        <input asp-for="VolumeL" class="form-control" type="number" step="0.1" min="0" />
                        <span class="input-group-text">L</span>
                    </div>
                    <span asp-validation-for="VolumeL" class="text-danger small"></span>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="HasDrainageHole" class="form-check-input" type="checkbox" />
                        <label asp-for="HasDrainageHole" class="form-check-label">@T("mygarden.container.field.drainage")</label>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="Notes" class="form-label">@T("common.notes")</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@T("common.save")</button>
                <a href="@Url.Action("List", "Container")" class="btn btn-outline-secondary">@T("common.cancel")</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
