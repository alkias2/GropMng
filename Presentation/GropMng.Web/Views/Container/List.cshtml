@model IList<GropMng.Core.Domain.Garden.Plants.Container>

@{
    GropHtml.SetActiveMenuItemSystemName("Containers");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">@T("mygarden.container.list.title")</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-style1">
                <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">@T("common.dashboard")</a></li>
                <li class="breadcrumb-item active">@T("mygarden.container.list.title")</li>
            </ol>
        </nav>
    </div>
    <a href="@Url.Action("Create", "Container")" class="btn btn-primary">
        <i class="bx bx-plus me-1"></i>@T("mygarden.container.add")
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@T("mygarden.container.list.title")</h5>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted mb-0">@T("mygarden.container.list.empty")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>@T("mygarden.container.field.type")</th>
                            <th>@T("mygarden.container.field.material")</th>
                            <th>@T("mygarden.container.field.volume")</th>
                            <th>@T("mygarden.container.field.color")</th>
                            <th>@T("mygarden.container.field.drainage")</th>
                            <th class="text-end">@T("common.actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td><span class="badge bg-label-success">@c.ContainerType</span></td>
                                <td>@(c.Material ?? "—")</td>
                                <td>@(c.VolumeL.HasValue ? $"{c.VolumeL:0.#}L" : "—")</td>
                                <td>@(c.Color ?? "—")</td>
                                <td>
                                    @if (c.HasDrainageHole)
                                    {
                                        <i class="bx bx-check-circle text-success" title="@T("common.yes")"></i>
                                    }
                                    else
                                    {
                                        <i class="bx bx-x-circle text-danger" title="@T("common.no")"></i>
                                    }
                                </td>
                                <td class="text-end">
                                    <a href="@Url.Action("Edit", "Container", new { id = c.Id })" class="btn btn-sm btn-icon btn-outline-primary" title="@T("common.edit")">
                                        <i class="bx bx-edit"></i>
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "Container", new { id = c.Id })" class="d-inline" data-grop-confirm="@T("common.delete.confirm")">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-icon btn-outline-danger" title="@T("common.delete")">
                                            <i class="bx bx-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
