@model GropMng.Core.Domain.Logging.AppLog
@{
    ViewData["Title"] = "Log Details";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title">Log #@Model.Id</h3>
                    <a asp-controller="AppLog" asp-action="Index" class="btn btn-secondary">Back</a>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-2">Level</dt>
                        <dd class="col-sm-10">@Model.Level</dd>

                        <dt class="col-sm-2">Category</dt>
                        <dd class="col-sm-10">@Model.Category</dd>

                        <dt class="col-sm-2">Message</dt>
                        <dd class="col-sm-10">@Model.Message</dd>

                        <dt class="col-sm-2">Exception Type</dt>
                        <dd class="col-sm-10">@Model.ExceptionType</dd>

                        <dt class="col-sm-2">Event Id</dt>
                        <dd class="col-sm-10">@Model.EventId</dd>

                        <dt class="col-sm-2">Request Path</dt>
                        <dd class="col-sm-10">@Model.RequestPath</dd>

                        <dt class="col-sm-2">Timestamp</dt>
                        <dd class="col-sm-10">@Model.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</dd>

                        <dt class="col-sm-2">Stack Trace</dt>
                        <dd class="col-sm-10">
                            <pre class="bg-light p-3 rounded">@Model.StackTrace</pre>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>
