@{
    ViewData["Title"] = "Application Logs";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h3>Application Logs</h3>
            <form asp-controller="AppLog" asp-action="DeleteAll" method="post" onsubmit="return confirm('Delete all logs?');">
                <button type="submit" class="btn btn-danger">Delete All</button>
            </form>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <select id="levelFilter" class="form-select">
                <option value="">All Levels</option>
                <option value="Information">Information</option>
                <option value="Warning">Warning</option>
                <option value="Error">Error</option>
                <option value="Critical">Critical</option>
            </select>
        </div>
        <div class="col-md-3">
            <input id="fromDateFilter" type="date" class="form-control" />
        </div>
        <div class="col-md-3">
            <input id="toDateFilter" type="date" class="form-control" />
        </div>
        <div class="col-md-3">
            <button id="applyFiltersBtn" class="btn btn-primary">Apply Filters</button>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="appLogsTable" class="table table-striped table-hover w-100">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Level</th>
                                    <th>Category</th>
                                    <th>Message</th>
                                    <th>Timestamp</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

    <script>
        const table = $('#appLogsTable').DataTable({
            processing: true,
            serverSide: true,
            ajax: {
                url: '@Url.Action("List", "AppLog")',
                type: 'POST',
                data: function (d) {
                    d.level = $('#levelFilter').val();
                    d.fromDate = $('#fromDateFilter').val();
                    d.toDate = $('#toDateFilter').val();
                }
            },
            columns: [
                { data: 'id' },
                { data: 'level' },
                { data: 'category' },
                { data: 'message' },
                {
                    data: 'timestamp',
                    render: function (data) {
                        return new Date(data).toLocaleString();
                    }
                },
                {
                    data: 'id',
                    orderable: false,
                    render: function (id) {
                        const detailsUrl = '@Url.Action("Details", "AppLog")/' + id;
                        const deleteUrl = '@Url.Action("Delete", "AppLog")';
                        return `
                            <a class="btn btn-sm btn-info me-1" href="${detailsUrl}">Details</a>
                            <form method="post" action="${deleteUrl}" style="display:inline;">
                                <input type="hidden" name="id" value="${id}" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete log?')">Delete</button>
                            </form>
                        `;
                    }
                }
            ]
        });

        $('#applyFiltersBtn').on('click', function () {
            table.ajax.reload();
        });
    </script>
}
