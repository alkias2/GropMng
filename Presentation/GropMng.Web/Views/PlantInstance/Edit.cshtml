@model GropMng.Web.Models.Garden.PlantInstanceModel

@{
    GropHtml.SetActiveMenuItemSystemName("MyPlants");
    var activeTab = Context.Request.Query["tab"].FirstOrDefault() ?? "details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">@(Model.PlantName) @(string.IsNullOrEmpty(Model.Nickname) ? "" : $"— {Model.Nickname}")</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-style1">
                <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">@T("common.dashboard")</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("List", "PlantInstance")">@T("mygarden.plantinstance.list.title")</a></li>
                <li class="breadcrumb-item active">@T("mygarden.plantinstance.edit.title")</li>
            </ol>
        </nav>
    </div>
    <form method="post" action="@Url.Action("Delete", "PlantInstance", new { id = Model.Id })" data-grop-confirm="@T("common.delete.confirm")">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger">
            <i class="bx bx-trash me-1"></i>@T("common.delete")
        </button>
    </form>
</div>

@* ── Tab Navigation ──────────────────────────────────────────────── *@
<ul class="nav nav-tabs mb-0" id="plantEditTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "details" ? "active" : "")"
                id="tab-details-btn" data-bs-toggle="tab" data-bs-target="#tab-details"
                type="button" role="tab" aria-controls="tab-details"
                aria-selected="@(activeTab == "details" ? "true" : "false")">
            @T("mygarden.plantinstance.tab.details")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "watering" ? "active" : "")"
                id="tab-watering-btn" data-bs-toggle="tab" data-bs-target="#tab-watering"
                type="button" role="tab" aria-controls="tab-watering"
                aria-selected="@(activeTab == "watering" ? "true" : "false")"
                data-lazy-url="@Url.Action("WateringScheduleTab", "PlantInstance", new { id = Model.Id })">
            @T("mygarden.plantinstance.tab.watering")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "fertilizing" ? "active" : "")"
                id="tab-fertilizing-btn" data-bs-toggle="tab" data-bs-target="#tab-fertilizing"
                type="button" role="tab" aria-controls="tab-fertilizing"
                aria-selected="@(activeTab == "fertilizing" ? "true" : "false")"
                data-lazy-url="@Url.Action("FertilizingScheduleTab", "PlantInstance", new { id = Model.Id })">
            @T("mygarden.plantinstance.tab.fertilizing")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "diseases" ? "active" : "")"
                id="tab-diseases-btn" data-bs-toggle="tab" data-bs-target="#tab-diseases"
                type="button" role="tab" aria-controls="tab-diseases"
                aria-selected="@(activeTab == "diseases" ? "true" : "false")"
                data-lazy-url="@Url.Action("DiseaseRecordTab", "PlantInstance", new { id = Model.Id })">
            @T("mygarden.plantinstance.tab.diseases")
            @if (Model.ActiveDiseaseCount > 0)
            {
                <span class="badge rounded-pill bg-danger ms-1">@Model.ActiveDiseaseCount</span>
            }
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "container" ? "active" : "")"
                id="tab-container-btn" data-bs-toggle="tab" data-bs-target="#tab-container"
                type="button" role="tab" aria-controls="tab-container"
                aria-selected="@(activeTab == "container" ? "true" : "false")"
                data-lazy-url="@Url.Action("ContainerRepottingTab", "PlantInstance", new { id = Model.Id })">
            @T("mygarden.plantinstance.tab.container")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "photos" ? "active" : "")"
                id="tab-photos-btn" data-bs-toggle="tab" data-bs-target="#tab-photos"
                type="button" role="tab" aria-controls="tab-photos"
                aria-selected="@(activeTab == "photos" ? "true" : "false")">
            @T("mygarden.plantinstance.tab.photos")
        </button>
    </li>
</ul>

@* ── Tab Content ─────────────────────────────────────────────────── *@
<div class="tab-content border border-top-0 rounded-bottom p-3 bg-body mb-4" id="plantEditTabContent">

    @* Tab: Details *@
    <div class="tab-pane fade @(activeTab == "details" ? "show active" : "")"
         id="tab-details" role="tabpanel" aria-labelledby="tab-details-btn">
        @await Html.PartialAsync("_DetailsTab", Model)
    </div>

    @* Tab: Watering — lazy-loaded via AJAX *@
    <div class="tab-pane fade @(activeTab == "watering" ? "show active" : "")"
         id="tab-watering" role="tabpanel" aria-labelledby="tab-watering-btn">
        @if (activeTab == "watering")
        {
            @await Html.PartialAsync("_WateringScheduleTab", Model.Id)
        }
        else
        {
            <div class="tab-lazy-placeholder text-center py-4">
                <span class="spinner-border spinner-border-sm text-primary d-none" role="status"></span>
            </div>
        }
    </div>

    @* Tab: Fertilizing — lazy-loaded via AJAX *@
    <div class="tab-pane fade @(activeTab == "fertilizing" ? "show active" : "")"
         id="tab-fertilizing" role="tabpanel" aria-labelledby="tab-fertilizing-btn">
        <div class="tab-lazy-placeholder text-center py-4">
            <span class="spinner-border spinner-border-sm text-primary d-none" role="status"></span>
        </div>
    </div>

    @* Tab: Diseases — lazy-loaded via AJAX *@
    <div class="tab-pane fade @(activeTab == "diseases" ? "show active" : "")"
         id="tab-diseases" role="tabpanel" aria-labelledby="tab-diseases-btn">
        <div class="tab-lazy-placeholder text-center py-4">
            <span class="spinner-border spinner-border-sm text-primary d-none" role="status"></span>
        </div>
    </div>

    @* Tab: Container — lazy-loaded via AJAX *@
    <div class="tab-pane fade @(activeTab == "container" ? "show active" : "")"
         id="tab-container" role="tabpanel" aria-labelledby="tab-container-btn">
        <div class="tab-lazy-placeholder text-center py-4">
            <span class="spinner-border spinner-border-sm text-primary d-none" role="status"></span>
        </div>
    </div>

    @* Tab: Photos *@
    <div class="tab-pane fade @(activeTab == "photos" ? "show active" : "")"
         id="tab-photos" role="tabpanel" aria-labelledby="tab-photos-btn">
        @await Html.PartialAsync("_PhotosTab", Model.Id)
    </div>

</div>

@* ── Watering Schedule Modal ─────────────────────────────────────── *@
@await Html.PartialAsync("_WateringScheduleForm", Model.Id)

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" asp-append-version="true" />
    <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js" asp-append-version="true"></script>
    <script src="~/js-custom/plant-instance-photos.js" asp-append-version="true"></script>
    <script src="~/js-custom/plant-instance-watering.js" asp-append-version="true"></script>
    <script src="~/js-custom/plant-instance-fertilizing.js" asp-append-version="true"></script>
    <script src="~/js-custom/plant-instance-diseases.js" asp-append-version="true"></script>
    <script src="~/js-custom/plant-instance-container.js" asp-append-version="true"></script>
    <script>
        GropPlantPhotos.init({
            plantInstanceId  : @Model.Id,
            tableId          : 'plant-photos-table-@Model.Id',
            addFormId        : 'plant-photos-add-@Model.Id',
            addUploadId      : 'plant-photos-upload-@Model.Id',
            editModalId      : 'plant-photos-edit-modal-@Model.Id',
            listUrl          : '@Url.Action("PlantPhotoList",   "PlantInstance", new { id = Model.Id })',
            addUrl           : '@Url.Action("PlantPhotoAdd",    "PlantInstance", new { id = Model.Id })',
            updateUrl        : '@Url.Action("PlantPhotoUpdate", "PlantInstance", new { id = Model.Id })',
            deleteUrl        : '@Url.Action("PlantPhotoDelete", "PlantInstance", new { id = Model.Id })',
            uploadUrl        : '@Url.Action("AsyncUpload", "Picture")',
            deleteConfirm    : '@T("mygarden.plantinstance.photo.delete.confirm")',
            msgUploading     : '@T("admin.picture.status.uploading")',
            msgUploadError   : '@T("admin.picture.status.error")'
        });

        GropPlantWatering.init({
            plantInstanceId   : @Model.Id,
            tabBtn            : document.getElementById('tab-watering-btn'),
            tabPane           : document.getElementById('tab-watering'),
            tabUrl            : '@Url.Action("WateringScheduleTab", "PlantInstance", new { id = Model.Id })',
            createUrl         : '@Url.Action("WateringScheduleCreate", "PlantInstance", new { id = Model.Id })',
            updateUrlTemplate : '@Url.Action("WateringScheduleUpdate", "PlantInstance", new { id = Model.Id, scheduleId = 0 })',
            deleteUrlTemplate : '@Url.Action("WateringScheduleDelete", "PlantInstance", new { id = Model.Id, scheduleId = 0 })',
            deleteLogUrlTemplate : '@Url.Action("WateringLogDelete", "PlantInstance", new { id = Model.Id, logId = 0 })',
            modalId           : 'watering-schedule-modal-@Model.Id',
            activeTab         : '@activeTab',
            deleteConfirm     : '@T("mygarden.watering.schedule.delete.confirm")',
            deleteLogConfirm  : '@T("mygarden.watering.log.delete.confirm")',
            msgSaveSuccess    : '@T("mygarden.watering.schedule.notifications.save.success")',
            msgDeleteSuccess  : '@T("mygarden.watering.schedule.notifications.delete.success")',
            msgDeleteLogSuccess : '@T("mygarden.watering.log.notifications.delete.success")'
        });

        GropPlantFertilizing.init({
            plantInstanceId   : @Model.Id,
            tabBtn            : document.getElementById('tab-fertilizing-btn'),
            tabPane           : document.getElementById('tab-fertilizing'),
            tabUrl            : '@Url.Action("FertilizingScheduleTab", "PlantInstance", new { id = Model.Id })',
            createUrl         : '@Url.Action("FertilizingScheduleCreate", "PlantInstance", new { id = Model.Id })',
            updateUrlTemplate : '@Url.Action("FertilizingScheduleUpdate", "PlantInstance", new { id = Model.Id, scheduleId = 0 })',
            deleteUrlTemplate : '@Url.Action("FertilizingScheduleDelete", "PlantInstance", new { id = Model.Id, scheduleId = 0 })',
            deleteLogUrlTemplate : '@Url.Action("FertilizingLogDelete", "PlantInstance", new { id = Model.Id, logId = 0 })',
            modalId           : 'fertilizing-schedule-modal-@Model.Id',
            activeTab         : '@activeTab',
            titleAdd          : '@T("mygarden.fertilizing.schedule.add")',
            titleEdit         : '@T("mygarden.fertilizing.schedule.edit")',
            validationRequired: '@T("mygarden.fertilizing.schedule.validation.required")',
            deleteConfirm     : '@T("mygarden.fertilizing.schedule.delete.confirm")',
            deleteLogConfirm  : '@T("mygarden.fertilizing.log.delete.confirm")',
            msgSaveSuccess    : '@T("mygarden.fertilizing.schedule.notifications.save.success")',
            msgDeleteSuccess  : '@T("mygarden.fertilizing.schedule.notifications.delete.success")',
            msgDeleteLogSuccess : '@T("mygarden.fertilizing.log.notifications.delete.success")',
            msgSaveError      : '@T("mygarden.fertilizing.schedule.notifications.save.error")',
            msgDeleteError    : '@T("mygarden.fertilizing.schedule.notifications.delete.error")',
            msgNetworkError   : '@T("common.networkerror")'
        });

        GropPlantDiseases.init({
            plantInstanceId       : @Model.Id,
            tabBtn                : document.getElementById('tab-diseases-btn'),
            tabPane               : document.getElementById('tab-diseases'),
            tabUrl                : '@Url.Action("DiseaseRecordTab", "PlantInstance", new { id = Model.Id })',
            createUrl             : '@Url.Action("DiseaseRecordCreate", "PlantInstance", new { id = Model.Id })',
            updateUrlTemplate     : '@Url.Action("DiseaseRecordUpdate", "PlantInstance", new { id = Model.Id, recordId = 0 })',
            deleteUrlTemplate     : '@Url.Action("DiseaseRecordDelete", "PlantInstance", new { id = Model.Id, recordId = 0 })',
            quickResolveUrlTemplate : '@Url.Action("DiseaseRecordQuickResolve", "PlantInstance", new { id = Model.Id, recordId = 0 })',
            addPhotoUrlTemplate   : '@Url.Action("DiseasePhotoAdd", "PlantInstance", new { id = Model.Id, recordId = 0 })',
            deletePhotoUrlTemplate: '@Url.Action("DiseasePhotoDelete", "PlantInstance", new { id = Model.Id, recordId = 0, photoId = 0 })',
            uploadUrl             : '@Url.Action("AsyncUpload", "Picture")',
            modalId               : 'disease-record-modal-@Model.Id',
            activeTab             : '@activeTab',
            titleAdd              : '@T("mygarden.disease.record.add")',
            titleEdit             : '@T("mygarden.disease.record.edit")',
            validationRequired    : '@T("mygarden.disease.record.validation.required")',
            deleteConfirm         : '@T("mygarden.disease.record.delete.confirm")',
            deletePhotoConfirm    : '@T("mygarden.disease.photo.delete.confirm")',
            msgSaveSuccess        : '@T("mygarden.disease.record.notifications.save.success")',
            msgSaveError          : '@T("mygarden.disease.record.notifications.save.error")',
            msgDeleteSuccess      : '@T("mygarden.disease.record.notifications.delete.success")',
            msgDeleteError        : '@T("mygarden.disease.record.notifications.delete.error")',
            msgResolveSuccess     : '@T("mygarden.disease.record.notifications.resolve.success")',
            msgPhotoRequired      : '@T("mygarden.disease.photo.validation.required")',
            msgPhotoAddSuccess    : '@T("mygarden.disease.photo.notifications.add.success")',
            msgPhotoDeleteSuccess : '@T("mygarden.disease.photo.notifications.delete.success")',
            msgUploading          : '@T("admin.picture.status.uploading")',
            msgUploadError        : '@T("admin.picture.status.error")',
            msgNetworkError       : '@T("common.networkerror")'
        });

        GropPlantContainer.init({
            plantInstanceId         : @Model.Id,
            tabBtn                  : document.getElementById('tab-container-btn'),
            tabPane                 : document.getElementById('tab-container'),
            tabUrl                  : '@Url.Action("ContainerRepottingTab", "PlantInstance", new { id = Model.Id })',
            createUrl               : '@Url.Action("RepottingCreate", "PlantInstance", new { id = Model.Id })',
            updateUrlTemplate       : '@Url.Action("RepottingUpdate", "PlantInstance", new { id = Model.Id, logId = 0 })',
            deleteUrlTemplate       : '@Url.Action("RepottingDelete", "PlantInstance", new { id = Model.Id, logId = 0 })',
            quickCreateContainerUrl : '@Url.Action("ContainerQuickCreate", "PlantInstance", new { id = Model.Id })',
            repottingModalId        : 'repotting-modal-@Model.Id',
            quickContainerModalId   : 'quick-container-modal-@Model.Id',
            activeTab               : '@activeTab',
            titleAdd                : '@T("mygarden.repotting.add")',
            titleEdit               : '@T("mygarden.repotting.edit")',
            validationDateRequired  : '@T("mygarden.repotting.validation.date")',
            deleteConfirm           : '@T("mygarden.repotting.delete.confirm")',
            deleteConfirmButtonText : '@T("mygarden.repotting.dialog.confirm")',
            msgSaveSuccess          : '@T("mygarden.repotting.notifications.save.success")',
            msgSaveError            : '@T("mygarden.repotting.notifications.save.error")',
            msgDeleteSuccess        : '@T("mygarden.repotting.notifications.delete.success")',
            msgDeleteError          : '@T("mygarden.repotting.notifications.delete.error")',
            msgContainerCreateSuccess : '@T("mygarden.repotting.container.notifications.create.success")',
            msgContainerCreateError : '@T("mygarden.repotting.container.notifications.create.error")',
            msgLoadError            : '@T("mygarden.repotting.notifications.load.error")',
            msgNetworkError         : '@T("common.networkerror")'
        });
    </script>
}
