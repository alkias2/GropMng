@model GropMng.Web.Models.Garden.FertilizingScheduleFormModel
@{
    var modalId = $"fertilizing-schedule-modal-{Model.PlantInstanceId}";
}
<div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="@(modalId)-title">@T("mygarden.fertilizing.schedule.add")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @Html.AntiForgeryToken()
                <input type="hidden" id="@(modalId)-schedule-id" value="0" />

                <div class="mb-3">
                    <label class="form-label">@T("mygarden.fertilizing.schedule.field.fertilizer") <span class="text-danger">*</span></label>
                    <select id="@(modalId)-fertilizerid" class="form-select">
                        <option value="">—</option>
                        @foreach (var fertilizer in Model.AvailableFertilizers)
                        {
                            <option value="@fertilizer.Value">@fertilizer.Text</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">@T("mygarden.fertilizing.schedule.field.season") <span class="text-danger">*</span></label>
                    <select id="@(modalId)-season" class="form-select">
                        <option value="Spring">@T("common.season.spring")</option>
                        <option value="Summer">@T("common.season.summer")</option>
                        <option value="Autumn">@T("common.season.autumn")</option>
                        <option value="Winter">@T("common.season.winter")</option>
                        <option value="AllYear">@T("common.season.allyear")</option>
                    </select>
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">@T("mygarden.fertilizing.schedule.field.frequencydays") <span class="text-danger">*</span></label>
                        <input type="number" id="@(modalId)-frequency" class="form-control" min="1" max="365" value="14" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@T("mygarden.fertilizing.schedule.field.quantity")</label>
                        <input type="text" id="@(modalId)-quantity" class="form-control" inputmode="decimal" autocomplete="off" placeholder="—" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@T("mygarden.fertilizing.schedule.field.unit")</label>
                        <select id="@(modalId)-unit" class="form-select">
                            <option value="">—</option>
                            <option value="Gram">@T("common.quantityunit.gram")</option>
                            <option value="Kilogram">@T("common.quantityunit.kilogram")</option>
                            <option value="Millilitre">@T("common.quantityunit.millilitre")</option>
                            <option value="Litre">@T("common.quantityunit.litre")</option>
                            <option value="Tablespoon">@T("common.quantityunit.tablespoon")</option>
                            <option value="Teaspoon">@T("common.quantityunit.teaspoon")</option>
                        </select>
                    </div>
                </div>

                <div class="mt-3">
                    <label class="form-label">@T("mygarden.fertilizing.schedule.field.notes")</label>
                    <textarea id="@(modalId)-notes" class="form-control" rows="2" maxlength="500"></textarea>
                </div>
                <div class="mt-3">
                    <label class="form-label">@T("mygarden.fertilizing.schedule.field.dilution")</label>
                    <textarea id="@(modalId)-dilution" class="form-control" rows="2" maxlength="500"></textarea>
                </div>
                <div id="@(modalId)-error" class="text-danger small mt-2 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">@T("common.cancel")</button>
                <button type="button" class="btn btn-primary btn-sm" id="@(modalId)-save-btn">@T("common.save")</button>
            </div>
        </div>
    </div>
</div>
