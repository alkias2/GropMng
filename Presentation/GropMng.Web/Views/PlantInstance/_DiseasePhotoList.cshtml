@model GropMng.Web.Models.Garden.DiseasePhotoListSectionModel
@{
    var uploadId = $"disease-photo-upload-{Model.RecordId}";
}
<div class="card card-body bg-label-secondary border-0 mt-2">
    <div class="row g-3 align-items-end mb-3">
        <div class="col-md-4">
            <label class="form-label">@T("mygarden.disease.photo.field.image")</label>
            <div id="@uploadId" class="border rounded p-2 bg-body">
                <input type="file" class="form-control form-control-sm mb-2" id="@(uploadId)-file" accept="image/*" />
                <input type="hidden" id="@(uploadId)-hidden" value="0" />
                <img id="@(uploadId)-preview" src="" class="img-fluid rounded border d-none" style="max-height:90px; object-fit:cover" />
                <div id="@(uploadId)-placeholder" class="small text-muted">@T("mygarden.disease.photo.upload.placeholder")</div>
                <div id="@(uploadId)-status" class="small text-muted mt-1"></div>
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label">@T("mygarden.disease.photo.field.takendate")</label>
            <input type="text" id="@(uploadId)-takendate" class="form-control form-control-sm flatpickr-date" autocomplete="off" value="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <label class="form-label">@T("mygarden.disease.photo.field.displayorder")</label>
            <input type="number" id="@(uploadId)-displayorder" class="form-control form-control-sm" min="0" max="9999" value="0" />
        </div>
        <div class="col-md-3">
            <label class="form-label">@T("mygarden.disease.photo.field.notes")</label>
            <input type="text" id="@(uploadId)-notes" class="form-control form-control-sm" maxlength="500" />
        </div>
        <div class="col-12 d-flex justify-content-end">
            <button type="button" class="btn btn-sm btn-primary disease-photo-add-btn" data-record-id="@Model.RecordId">
                <i class="bx bx-image-add me-1"></i>@T("mygarden.disease.photo.add")
            </button>
        </div>
    </div>

    @if (!Model.Photos.Any())
    {
        <p class="small text-muted mb-0">@T("mygarden.disease.photo.empty")</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:90px">@T("mygarden.disease.photo.field.image")</th>
                        <th style="width:120px">@T("mygarden.disease.photo.field.takendate")</th>
                        <th style="width:90px">@T("mygarden.disease.photo.field.displayorder")</th>
                        <th>@T("mygarden.disease.photo.field.notes")</th>
                        <th style="width:100px" class="text-end">@T("common.actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var photo in Model.Photos)
                    {
                        <tr>
                            <td>
                                <img src="@photo.ThumbnailUrl" class="rounded border" style="width:60px;height:60px;object-fit:cover" />
                            </td>
                            <td class="small">@photo.TakenDate.ToString("yyyy-MM-dd")</td>
                            <td class="small">@photo.DisplayOrder</td>
                            <td class="small text-muted">@(photo.Notes ?? "—")</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-danger disease-photo-delete-btn"
                                        data-record-id="@Model.RecordId"
                                        data-photo-id="@photo.Id"
                                        title="@T("common.delete")">
                                    <i class="bx bx-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
