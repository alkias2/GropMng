@model GropMng.Web.Models.Garden.DiseaseRecordTabModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="mb-0">@T("mygarden.disease.record.title")</h6>
    <button type="button" class="btn btn-sm btn-primary" id="disease-record-add-btn-@Model.PlantInstanceId">
        <i class="bx bx-plus me-1"></i>@T("mygarden.disease.record.add")
    </button>
</div>

@await Html.PartialAsync("_DiseaseRecordList", Model)

@await Html.PartialAsync("_DiseaseRecordForm", new GropMng.Web.Models.Garden.DiseaseRecordFormModel
{
    PlantInstanceId = Model.PlantInstanceId,
    AvailableDiseases = Model.AvailableDiseases
})
