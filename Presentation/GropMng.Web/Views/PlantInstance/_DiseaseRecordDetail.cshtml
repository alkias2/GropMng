@model GropMng.Web.Models.Garden.DiseaseRecordRowModel

<div class="small text-muted">
    <div>
        <strong>@T("mygarden.disease.record.field.treatment"):</strong>
        @(string.IsNullOrWhiteSpace(Model.TreatmentUsed) ? "—" : Model.TreatmentUsed)
    </div>
    <div class="mt-1">
        <strong>@T("mygarden.disease.record.field.notes"):</strong>
        @if (string.IsNullOrWhiteSpace(Model.Notes))
        {
            <span>—</span>
        }
        else
        {
            <div class="ql-editor p-0">@Html.Raw(Model.Notes)</div>
        }
    </div>
</div>
