@model GropMng.Web.Models.Garden.DiseaseRecordFormModel
@{
    var modalId = $"disease-record-modal-{Model.PlantInstanceId}";
}
<div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"
                    id="@(modalId)-title"
                    data-title-add="@T("mygarden.disease.record.add")"
                    data-title-edit="@T("mygarden.disease.record.edit")">
                    @T("mygarden.disease.record.add")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @Html.AntiForgeryToken()
                <input type="hidden" id="@(modalId)-record-id" value="0" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">@T("mygarden.disease.record.field.disease") <span class="text-danger">*</span></label>
                        <select id="@(modalId)-diseaseid" class="form-select">
                            <option value="">—</option>
                            @foreach (var disease in Model.AvailableDiseases)
                            {
                                <option value="@disease.Value">@disease.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@T("mygarden.disease.record.field.detected") <span class="text-danger">*</span></label>
                        <input type="text" id="@(modalId)-detected" class="form-control flatpickr-date" autocomplete="off" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@T("mygarden.disease.record.field.resolved")</label>
                        <input type="text" id="@(modalId)-resolved" class="form-control flatpickr-date" autocomplete="off" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">@T("mygarden.disease.record.field.severity")</label>
                        <select id="@(modalId)-severity" class="form-select">
                            <option value="">—</option>
                            <option value="Mild">@T("mygarden.disease.severity.mild")</option>
                            <option value="Moderate">@T("mygarden.disease.severity.moderate")</option>
                            <option value="Severe">@T("mygarden.disease.severity.severe")</option>
                            <option value="Critical">@T("mygarden.disease.severity.critical")</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@T("mygarden.disease.record.field.outcome")</label>
                        <select id="@(modalId)-outcome" class="form-select">
                            <option value="">—</option>
                            <option value="Ongoing">@T("mygarden.disease.outcome.ongoing")</option>
                            <option value="Resolved">@T("mygarden.disease.outcome.resolved")</option>
                            <option value="Lost">@T("mygarden.disease.outcome.lost")</option>
                            <option value="Unknown">@T("mygarden.disease.outcome.unknown")</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@T("mygarden.disease.record.field.treatment")</label>
                        <textarea id="@(modalId)-treatment" class="form-control" rows="3" maxlength="500"></textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label">@T("mygarden.disease.record.field.notes")</label>
                        <textarea id="@(modalId)-notes" class="form-control" maxlength="1000"></textarea>
                        <div class="grop-quill-editor" data-quill-mode="full" data-input-selector="#@(modalId)-notes"></div>
                    </div>
                </div>

                <div id="@(modalId)-error" class="text-danger small mt-2 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">@T("common.cancel")</button>
                <button type="button" class="btn btn-primary btn-sm" id="@(modalId)-save-btn">@T("common.save")</button>
            </div>
        </div>
    </div>
</div>
