@model GropMng.Web.Models.OwnerAuth.OwnerForgotPasswordModel
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<div class="card">
    <div class="card-body">
        <div class="app-brand justify-content-center mb-4">
            <a asp-controller="Home" asp-action="Index" class="app-brand-link gap-2">
                <span class="app-brand-logo">
                    <img src="~/grop-mng-logo.svg" alt="GropMng" />
                </span>
                <span class="app-brand-text demo text-body fw-bold">GropMng</span>
            </a>
        </div>

        <h4 class="mb-2">Forgot your password?</h4>
        <p class="mb-4">Enter your email and we will prepare a reset link for your owner account.</p>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <form asp-action="ForgotPassword" asp-controller="OwnerAuth" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary d-grid w-100">Request reset link</button>
        </form>

        <p class="text-center mt-4 mb-0">
            <a asp-action="Login" asp-controller="OwnerAuth">Back to sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
