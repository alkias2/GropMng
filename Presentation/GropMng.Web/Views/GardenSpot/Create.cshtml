@model GropMng.Web.Models.Garden.GardenSpotModel

@{
    GropHtml.SetActiveMenuItemSystemName("Locations");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">@T("mygarden.gardenspot.create.title")</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-style1">
                <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">@T("common.dashboard")</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("List", "Location")">@T("mygarden.location.list.title")</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Edit", "Location", new { id = Model.LocationId })">@Model.LocationName</a></li>
                <li class="breadcrumb-item active">@T("mygarden.gardenspot.create.title")</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" asp-controller="GardenSpot" asp-route-locationId="@Model.LocationId" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">@T("mygarden.gardenspot.field.picture")</label>
                    @Html.EditorFor(m => m.PictureId, additionalViewData: new { PictureEntityType = "gardenspot" })
                </div>
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label">@T("mygarden.gardenspot.field.name") <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Orientation" class="form-label">@T("mygarden.gardenspot.field.orientation")</label>
                    <select asp-for="Orientation" asp-items="Model.AvailableOrientations" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="CoverType" class="form-label">@T("mygarden.gardenspot.field.covertype")</label>
                    <select asp-for="CoverType" asp-items="Model.AvailableCoverTypes" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="SunHoursPerDay" class="form-label">@T("mygarden.gardenspot.field.sunhours")</label>
                    <input asp-for="SunHoursPerDay" class="form-control" type="number" min="0" max="24" />
                    <span asp-validation-for="SunHoursPerDay" class="text-danger small"></span>
                </div>
                <div class="col-md-9">
                    <label asp-for="Surroundings" class="form-label">@T("mygarden.gardenspot.field.surroundings")</label>
                    <input asp-for="Surroundings" class="form-control" />
                    <span asp-validation-for="Surroundings" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label">@T("common.notes")</label>
                    <textarea asp-for="Notes" class="form-control"></textarea>
                    <div class="grop-quill-editor" data-quill-mode="mini" data-input-selector="#Notes"></div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@T("common.save")</button>
                <a href="@Url.Action("Edit", "Location", new { id = Model.LocationId })" class="btn btn-outline-secondary">@T("common.cancel")</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
