@model GropMng.Web.Areas.Admin.Models.Owner.OwnerSearchModel
@using GropMng.Web.Areas.Admin.Models.Owner
@using GropMng.Web.Framework.Models.DataTables
@using GropMng.Web.Framework.TagHelpers.Admin
@using Microsoft.AspNetCore.Routing
@{
    ViewData["Title"] = "Owners";
    GropHtml.SetActiveMenuItemSystemName("Owners");
}

<grop-admin-page-header
    title="Owners"
    breadcrumbs="@(new List<AdminBreadcrumbItemModel>
    {
        new() { Text = "Dashboard", Url = Url.Action("Dashboard", "Home", new { area = "" }) },
        new() { Text = "Owners" }
    })">
</grop-admin-page-header>

@await Html.PartialAsync("Notifications")

@Html.AntiForgeryToken()

<div class="card mb-4">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 me-auto">Owner filters</h5>
        <button id="btnApplyFilters" class="btn btn-primary btn-sm">
            <i class="bx bx-filter-alt me-1"></i> Apply
        </button>
        <button id="btnClearFilters" class="btn btn-outline-secondary btn-sm ms-2">
            <i class="bx bx-x me-1"></i> Clear
        </button>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="SearchTerm" class="form-label"></label>
                <input asp-for="SearchTerm" class="form-control" placeholder="Search by name or email" />
            </div>
            <div class="col-md-4">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="Model.AvailableStatuses" class="form-select"></select>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("Table", new GropDataTablesModel
{
    Name = "ownersTable",
    UrlRead = new GropDataUrl("OwnerList", "Owner", new RouteValueDictionary(new { area = "Admin" })),
    SearchButtonId = "btnApplyFilters",
    ClearButtonId = "btnClearFilters",
    Length = Model.PageSize,
    LengthMenu = [10, 25, 50, 100],
    Filters =
    [
        new GropFilterParameter(nameof(OwnerSearchModel.SearchTerm)),
        new GropFilterParameter(nameof(OwnerSearchModel.Status))
    ],
    ColumnCollection =
    [
        new GropColumnProperty("displayName")
        {
            Title = "Display name"
        },
        new GropColumnProperty("email")
        {
            Title = "Email"
        },
        new GropColumnProperty("status")
        {
            Title = "Status",
            Width = "140px",
            Render = new RenderBadge("badge bg-label-primary")
        },
        new GropColumnProperty("rolesSummary")
        {
            Title = "Roles",
            Orderable = false
        },
        new GropColumnProperty("isEmailConfirmed")
        {
            Title = "Confirmed",
            Width = "110px",
            Render = new RenderBoolean { TrueClass = "badge bg-label-success", FalseClass = "badge bg-label-warning" }
        },
        new GropColumnProperty("ownerId")
        {
            Title = "Edit",
            Width = "80px",
            ClassName = GropColumnClassDefaults.Button,
            Orderable = false,
            Searchable = false,
            Render = new RenderButtonEdit(new GropDataUrl("Edit", "Owner", new RouteValueDictionary(new { area = "Admin" })))
        }
    ]
})

