@model GropMng.Web.Areas.Admin.Models.Owner.OwnerEditModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-md-6">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DisplayName" class="form-label"></label>
        <input asp-for="DisplayName" class="form-control" />
        <span asp-validation-for="DisplayName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<GropMng.Core.Domain.Garden.Enums.OwnerAccountStatus>()" class="form-select"></select>
    </div>
    <div class="col-md-4 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" asp-for="IsActive" />
            <label class="form-check-label" asp-for="IsActive"></label>
        </div>
    </div>
    <div class="col-md-4 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" asp-for="IsEmailConfirmed" />
            <label class="form-check-label" asp-for="IsEmailConfirmed"></label>
        </div>
    </div>
</div>

<hr class="my-4" />

<h5 class="mb-3">@T("admin.owner.roles.assigned")</h5>
<div class="row g-3">
    @foreach (var role in Model.AvailableRoles)
    {
        <div class="col-md-6">
            <label class="form-check form-check-custom">
                <input class="form-check-input" type="checkbox" name="SelectedRoleSystemNames" value="@role.Value" checked="@role.Selected" />
                <span class="form-check-label">@role.Text</span>
            </label>
        </div>
    }
</div>

@if (Model.IsSystemAdministrator)
{
    <div class="alert alert-warning mt-4 mb-0">
        @T("admin.owner.roles.warning.systemadministrator")
    </div>
}

<hr class="my-4" />

<h5 class="mb-3">@T("admin.owner.password.section.title")</h5>
<div class="row g-3 align-items-end">
    <div class="col-md-6">
        <label asp-for="Password" class="form-label">@T("admin.owner.password.field.new")</label>
        <div class="input-group input-group-merge">
            <input asp-for="Password"
                   type="password"
                   class="form-control"
                   autocomplete="new-password"
                   data-password-toggle-target="owner-new-password" />
            <button type="button"
                    class="input-group-text cursor-pointer"
                    data-password-toggle-button="owner-new-password"
                    aria-label="Toggle password visibility">
                <i class="bx bx-hide"></i>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <button type="submit"
                name="changepassword"
                value="true"
                formaction="@Url.Action("ChangePassword", "Owner", new { area = "Admin" })"
                class="btn btn-outline-primary">
            @T("admin.owner.password.change.button")
        </button>
    </div>
</div>


