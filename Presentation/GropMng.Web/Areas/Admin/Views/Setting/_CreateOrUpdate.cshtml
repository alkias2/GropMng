@model GropMng.Web.Areas.Admin.Models.Settings.GropAdminAreaSettingsModel

<div class="row g-3">
    <div class="col-md-4">
        <grop-label asp-for="DefaultGridPageSize" />
        <grop-editor asp-for="DefaultGridPageSize" html-attributes='new { type = "number", min = "1", max = "200" }' />
        <span class="text-danger" asp-validation-for="DefaultGridPageSize"></span>
    </div>

    <div class="col-md-8">
        <grop-label asp-for="GridPageSizes" />
        <grop-editor asp-for="GridPageSizes" html-attributes='new { placeholder = "10,20,50" }' />
        <span class="text-danger" asp-validation-for="GridPageSizes"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="RichEditorProvider" />
        <grop-editor asp-for="RichEditorProvider" />
        <span class="text-danger" asp-validation-for="RichEditorProvider"></span>
        <div class="form-text">Expected value for current UI template: Quill</div>
    </div>

    <div class="col-12">
        <grop-label asp-for="AdminDashboardWelcomeHtml" />
        <grop-editor asp-for="AdminDashboardWelcomeHtml" asp-template="RichEditor" />
        <span class="text-danger" asp-validation-for="AdminDashboardWelcomeHtml"></span>
        <div class="form-text">This HTML block is edited with Quill and can be displayed on Admin dashboard pages.</div>
    </div>

    <div class="col-md-3 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" asp-for="RichEditorAllowHtml" />
            <label class="form-check-label" asp-for="RichEditorAllowHtml"></label>
        </div>
    </div>

    <div class="col-md-3 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" asp-for="RequireEmailConfirmation" />
            <label class="form-check-label" asp-for="RequireEmailConfirmation"></label>
        </div>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="PasswordResetTokenExpirationHours" />
        <grop-editor asp-for="PasswordResetTokenExpirationHours" html-attributes='new { type = "number", min = "1", max = "168" }' />
        <span class="text-danger" asp-validation-for="PasswordResetTokenExpirationHours"></span>
        <div class="form-text">Controls the lifetime of owner password reset links.</div>
    </div>

    <div class="col-md-3 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" asp-for="UseIsoDateFormatInJsonResult" />
            <label class="form-check-label" asp-for="UseIsoDateFormatInJsonResult"></label>
        </div>
    </div>
</div>

<div class="mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="bx bx-save me-1"></i> Save Settings
    </button>
</div>