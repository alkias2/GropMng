@model GropMng.Web.Areas.Admin.Models.Settings.GropAdminAreaSettingsModel
@{
    ViewData["Title"] = "Admin Settings";
    GropHtml.SetActiveMenuItemSystemName("AdminSettings");

    var headerModel = new AdminPageHeaderModel
    {
        Title = "Admin Settings",
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = "Dashboard", Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = "Admin Settings" }
        },
        ActionButtons = new Microsoft.AspNetCore.Html.HtmlString(
            "<button type=\"submit\" form=\"settingsForm\" class=\"btn btn-primary\"><i class=\"bx bx-save me-1\"></i> " + T("common.save") + "</button>")
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form id="settingsForm" asp-area="Admin" asp-controller="Setting" asp-action="AdminArea" method="post">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("_CreateOrUpdate", Model)
        </form>
    </div>
</div>
