@model GropMng.Web.Areas.Admin.Models.Roles.OwnerRoleEditModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" readonly="@Model.IsSystemRole" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="SystemName" class="form-label"></label>
        <input asp-for="SystemName" class="form-control" readonly="@Model.IsSystemRole" />
        <span asp-validation-for="SystemName" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="col-md-4 d-flex align-items-center">
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" asp-for="IsActive" />
            <label class="form-check-label" asp-for="IsActive"></label>
        </div>
    </div>
    <div class="col-md-8 d-flex align-items-center">
        @if (Model.IsSystemRole)
        {
            <div class="alert alert-info mb-0 w-100">
                This is a system role. Name and system name remain locked, but permissions can be reviewed and updated.
            </div>
        }
    </div>
</div>

<hr class="my-4" />

@await Html.PartialAsync("~/Areas/Admin/Views/Shared/_PermissionsCheckboxGrid.cshtml", Model.PermissionGroups)
