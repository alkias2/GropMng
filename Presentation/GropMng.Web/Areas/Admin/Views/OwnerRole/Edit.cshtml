@model GropMng.Web.Areas.Admin.Models.Roles.OwnerRoleEditModel
@{
    ViewData["Title"] = "Edit Role";
    GropHtml.SetActiveMenuItemSystemName("Roles");

    var saveText = T("common.save");
    var cancelText = T("common.cancel");
    var listUrl = Url.Action("List", "OwnerRole", new { area = "Admin" })!;
    var headerModel = new AdminPageHeaderModel
    {
        Title = Model.Name,
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = "Dashboard", Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = "Roles & Permissions", Url = listUrl },
            new() { Text = "Edit Role" }
        },
        ActionButtons = new Microsoft.AspNetCore.Html.HtmlString(
            "<a href=\"" + listUrl + "\" class=\"btn btn-label-secondary\"><i class=\"bx bx-arrow-back me-1\"></i> " + cancelText + "</a>" +
            " <button type=\"submit\" form=\"ownerRoleEditForm\" class=\"btn btn-primary\"><i class=\"bx bx-save me-1\"></i> " + saveText + "</button>")
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form id="ownerRoleEditForm" asp-area="Admin" asp-controller="OwnerRole" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            @await Html.PartialAsync("_CreateOrUpdate", Model)
        </form>
    </div>
</div>
