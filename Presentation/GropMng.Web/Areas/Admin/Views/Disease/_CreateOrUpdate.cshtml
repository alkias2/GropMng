@model GropMng.Web.Areas.Admin.Models.Disease.DiseaseModel

@{
    var localizedDiseaseTypes = Model.AvailableDiseaseTypes
        .Select(item => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = item.Value,
            Text = string.IsNullOrWhiteSpace(item.Value)
                ? T("common.none")
                : T($"admin.disease.diseasetype.{item.Value.ToLowerInvariant()}"),
            Selected = item.Selected
        })
        .ToList();
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-md-8">
        <grop-label asp-for="Name" />
        <grop-editor asp-for="Name" asp-required="true" />
        <span class="text-danger" asp-validation-for="Name"></span>
    </div>

    <div class="col-md-4">
        <grop-label asp-for="DiseaseType" />
        <grop-select asp-for="DiseaseType" asp-items="localizedDiseaseTypes" />
        <span class="text-danger" asp-validation-for="DiseaseType"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="AffectedParts" />
        <grop-editor asp-for="AffectedParts" />
        <span class="text-danger" asp-validation-for="AffectedParts"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="Symptoms" />
        <grop-textarea asp-for="Symptoms" asp-rows="3" />
        <span class="text-danger" asp-validation-for="Symptoms"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="PreventionNotes" />
        <grop-textarea asp-for="PreventionNotes" asp-rows="3" />
        <span class="text-danger" asp-validation-for="PreventionNotes"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="Notes" />
        <grop-textarea asp-for="Notes" asp-rows="3" />
        <span class="text-danger" asp-validation-for="Notes"></span>
    </div>
</div>
