@model GropMng.Web.Areas.Admin.Models.Disease.DiseaseRemedyLinkModel

@{
    var localizedTreatmentTypes = Model.AvailableTreatmentTypes
        .Select(item => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = item.Value,
            Text = string.IsNullOrWhiteSpace(item.Value)
                ? T("common.none")
                : T($"admin.disease.treatmenttype.{item.Value.ToLowerInvariant()}"),
            Selected = item.Selected
        })
        .ToList();
}

<form id="addRemedyLinkForm"
      asp-area="Admin" asp-controller="Disease" asp-action="AddRemedyLink"
      method="post">
    @Html.AntiForgeryToken()
    <input asp-for="DiseaseId" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <grop-label asp-for="PesticideId" />
            <grop-select asp-for="PesticideId" asp-items="Model.AvailablePesticides" />
            <span class="text-danger" asp-validation-for="PesticideId"></span>
        </div>

        <div class="col-md-6">
            <grop-label asp-for="TreatmentType" />
            <grop-select asp-for="TreatmentType" asp-items="localizedTreatmentTypes" />
            <span class="text-danger" asp-validation-for="TreatmentType"></span>
        </div>

        <div class="col-md-4">
            <grop-label asp-for="Dosage" />
            <grop-editor asp-for="Dosage" />
        </div>

        <div class="col-md-4">
            <grop-label asp-for="Frequency" />
            <grop-editor asp-for="Frequency" />
        </div>

        <div class="col-md-4">
            <grop-label asp-for="Notes" />
            <grop-editor asp-for="Notes" />
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">@T("common.cancel")</button>
        <button type="submit" class="btn btn-primary">
            <i class="bx bx-link me-1"></i> @T("admin.disease.remedylink.add")
        </button>
    </div>
</form>
