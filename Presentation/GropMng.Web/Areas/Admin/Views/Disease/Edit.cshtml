@using GropMng.Web.Framework.TagHelpers.Admin
@model GropMng.Web.Areas.Admin.Models.Disease.DiseaseModel
@{
    ViewData["Title"] = T("admin.disease.edit");
    GropHtml.SetActiveMenuItemSystemName("Diseases");

    var listUrl = Url.Action("List", "Disease", new { area = "Admin" })!;
    var remedyLinkListUrl = Url.Action("RemedyLinkList", "Disease", new { area = "Admin", diseaseId = Model.Id })!;
    var addRemedyLinkFormUrl = Url.Action("AddRemedyLinkForm", "Disease", new { area = "Admin", diseaseId = Model.Id })!;
    var deleteRemedyLinkUrl = Url.Action("DeleteRemedyLink", "Disease", new { area = "Admin" })!;
}

<grop-admin-page-header
    title="@($"{T("common.edit")}: {Model.Name}")"
    breadcrumbs="@(new List<AdminBreadcrumbItemModel>
    {
        new() { Text = T("common.dashboard"), Url = Url.Action("Index", "Home", new { area = "" }) },
        new() { Text = T("admin.disease.title"), Url = listUrl },
        new() { Text = T("common.edit") }
    })">
    <grop-header-button href="@listUrl"
                        text="@T("common.cancel")"
                        icon="bx bx-arrow-back"
                        css-class="btn btn-label-secondary" />
    <grop-header-button form="diseaseEditForm"
                        type="submit"
                        text="@T("common.save")"
                        icon="bx bx-save"
                        css-class="btn btn-primary" />
</grop-admin-page-header>

@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form id="diseaseEditForm" asp-area="Admin" asp-controller="Disease" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            @await Html.PartialAsync("_CreateOrUpdate", Model)
        </form>
    </div>
</div>

@* Remedy Links sub-section *@
<div class="card mt-4">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 me-auto">@T("admin.disease.remedylinks.title")</h5>
        <button type="button" class="btn btn-primary btn-sm" id="btnAddRemedyLink">
            <i class="bx bx-plus me-1"></i> @T("admin.disease.remedylink.add")
        </button>
    </div>
    <div class="card-body">
        <table id="remedyLinksTable" class="table table-hover dt-responsive w-100">
            <thead>
                <tr>
                    <th>@T("admin.disease.remedylink.fields.pesticide")</th>
                    <th>@T("admin.disease.remedylink.fields.treatmenttype")</th>
                    <th>@T("admin.disease.remedylink.fields.dosage")</th>
                    <th>@T("admin.disease.remedylink.fields.frequency")</th>
                    <th class="text-center">@T("common.delete")</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@* Add Remedy Link Modal *@
<div class="modal fade" id="remedyLinkModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@T("admin.disease.remedylink.add")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="remedyLinkFormContainer">
                <div class="d-flex justify-content-center">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4 border-danger">
    <div class="card-header">
        <h5 class="card-title text-danger mb-0">@T("common.dangerzone")</h5>
    </div>
    <div class="card-body d-flex justify-content-between align-items-center">
        <p class="mb-0">@T("admin.disease.delete.confirm") @T("common.delete.cannotundo")</p>
        <form asp-area="Admin"
              asp-controller="Disease"
              asp-action="Delete"
              method="post"
              data-grop-delete="true">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bx bx-trash me-1"></i> @T("admin.disease.delete")
            </button>
        </form>
    </div>
</div>

@section Vendors {
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
}

@section Scripts {
<script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
<script>
    (function () {
        'use strict';

        const diseaseId = @Model.Id;
        const remedyLinkListUrl = '@Html.Raw(remedyLinkListUrl)';
        const addRemedyLinkFormUrl = '@Html.Raw(addRemedyLinkFormUrl)';
        const deleteRemedyLinkUrl = '@Html.Raw(deleteRemedyLinkUrl)';
        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').first().val();

        // Initialize DataTable for remedy links
        const remedyTable = $('#remedyLinksTable').DataTable({
            ajax: {
                url: remedyLinkListUrl,
                type: 'GET',
                dataSrc: 'data'
            },
            columns: [
                { data: 'pesticideName' },
                { data: 'treatmentTypeLocalized' },
                { data: 'dosage', defaultContent: '' },
                { data: 'frequency', defaultContent: '' },
                {
                    data: 'id',
                    className: 'text-center',
                    orderable: false,
                    render: function (id, _, row) {
                        return `<form method="post" action="${deleteRemedyLinkUrl}" style="display:inline">
                            <input type="hidden" name="__RequestVerificationToken" value="${antiForgeryToken}">
                            <input type="hidden" name="id" value="${id}">
                            <input type="hidden" name="diseaseId" value="${row.diseaseId}">
                            <button type="submit" class="btn btn-sm btn-label-danger"
                                    onclick="return confirm('@T("common.delete.confirm")')">
                                <i class="bx bx-trash"></i>
                            </button>
                        </form>`;
                    }
                }
            ],
            paging: false,
            searching: false,
            info: false
        });

        // Load form into modal and show
        $('#btnAddRemedyLink').on('click', function () {
            $('#remedyLinkFormContainer').load(addRemedyLinkFormUrl, function () {
                $('#remedyLinkModal').modal('show');
            });
        });

        // Handle AJAX form submission inside modal
        $(document).on('submit', '#addRemedyLinkForm', function (e) {
            e.preventDefault();
            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                data: $(this).serialize(),
                success: function (result) {
                    if (result.success) {
                        $('#remedyLinkModal').modal('hide');
                        remedyTable.ajax.reload();
                    } else {
                        alert(result.message || 'Error adding remedy link.');
                    }
                }
            });
        });
    })();
</script>
}
