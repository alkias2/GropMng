@model GropMng.Web.Areas.Admin.Models.Localization.LocaleResourceModel
@{
    ViewData["Title"] = T("admin.localization.resource.edit");
    GropHtml.SetActiveMenuItemSystemName("Localization");

    var titleText = (string)ViewData["Title"]!;
    var dashboardText = T("common.dashboard");
    var languagesText = T("admin.localization.languages.title");
    var resourcesText = T("admin.localization.resources.title");

    var headerModel = new AdminPageHeaderModel
    {
        Title = titleText,
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = dashboardText, Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = languagesText, Url = Url.Action("List", "Localization", new { area = "Admin" }) },
            new() { Text = resourcesText, Url = Url.Action("Resources", "Localization", new { area = "Admin", languageId = Model.LanguageId }) },
            new() { Text = titleText }
        }
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Localization" asp-action="EditResource" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="LanguageId" type="hidden" />
            <partial name="_ResourceForm" model="Model" />
        </form>
    </div>
</div>

