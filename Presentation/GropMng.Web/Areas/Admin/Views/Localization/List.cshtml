@model GropMng.Web.Areas.Admin.Models.Localization.LanguageSearchModel
@using GropMng.Web.Areas.Admin.Models.Localization
@using GropMng.Web.Framework.Models.DataTables
@using Microsoft.AspNetCore.Routing
@{
    ViewData["Title"] = T("admin.localization.languages.title");
    GropHtml.SetActiveMenuItemSystemName("Localization");

    var titleText = (string)ViewData["Title"]!;
    var dashboardText = T("common.dashboard");

    var headerModel = new AdminPageHeaderModel
    {
        Title = titleText,
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = dashboardText, Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = titleText }
        }
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

@Html.AntiForgeryToken()

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Localization" asp-action="Create">
            <i class="bx bx-plus me-1"></i> @T("admin.localization.language.create")
        </a>
    </div>
</div>

@await Html.PartialAsync("Table", new GropDataTablesModel
{
    Name = "languagesTable",
    UrlRead = new GropDataUrl("LanguageList", "Localization", new RouteValueDictionary(new { area = "Admin" })),
    SearchButtonId = "btnApplyFilters",
    ClearButtonId = "btnClearFilters",
    Length = Model.PageSize,
    LengthMenu = [10, 25, 50, 100],
    ColumnCollection =
    [
        new GropColumnProperty("id")
        {
            Title = T("admin.localization.language.fields.id"),
            Width = "80px",
        },
        new GropColumnProperty("name")
        {
            Title = T("admin.localization.language.fields.name"),
            Width = "200px",
        },
        new GropColumnProperty("languageCulture")
        {
            Title = T("admin.localization.language.fields.culture"),
            Width = "150px",
        },
        new GropColumnProperty("uniqueSeoCode")
        {
            Title = T("admin.localization.language.fields.seocode"),
            Width = "100px",
        },
        new GropColumnProperty("published")
        {
            Title = T("admin.localization.language.fields.published"),
            Width = "100px",
            ClassName = GropColumnClassDefaults.CenterAll,
            Render = new RenderBoolean(),
        },
        new GropColumnProperty("displayOrder")
        {
            Title = T("admin.localization.language.fields.displayorder"),
            Width = "100px",
            ClassName = GropColumnClassDefaults.CenterAll,
        },
        new GropColumnProperty("id")
        {
            Title = T("common.edit"),
            Width = "80px",
            ClassName = GropColumnClassDefaults.Button,
            Orderable = false,
            Searchable = false,
            Render = new RenderButtonEdit(new GropDataUrl("Edit", "Localization", new RouteValueDictionary(new { area = "Admin" }))),
        },
        new GropColumnProperty("id")
        {
            Title = T("admin.localization.language.manage"),
            Width = "140px",
            ClassName = GropColumnClassDefaults.Button,
            Orderable = false,
            Searchable = false,
            Render = new RenderButtonView(new GropDataUrl("Resources", "Localization", new RouteValueDictionary(new { area = "Admin" }))),
        }
    ]
})

@section Vendors {
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
}

@section Scripts {
    <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
}
