@model GropMng.Web.Areas.Admin.Models.Localization.LanguageModel
@{
    ViewData["Title"] = T("admin.localization.language.create");
    GropHtml.SetActiveMenuItemSystemName("Localization");

    var titleText = (string)ViewData["Title"]!;
    var dashboardText = T("common.dashboard");
    var languagesText = T("admin.localization.languages.title");
    var listUrl = Url.Action("List", "Localization", new { area = "Admin" })!;
    var saveText = T("common.save");
    var cancelText = T("common.cancel");

    var headerModel = new AdminPageHeaderModel
    {
        Title = titleText,
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = dashboardText, Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = languagesText, Url = listUrl },
            new() { Text = titleText }
        },
        ActionButtons = new Microsoft.AspNetCore.Html.HtmlString(
            "<a href=\"" + listUrl + "\" class=\"btn btn-label-secondary\"><i class=\"bx bx-arrow-back me-1\"></i> " + cancelText + "</a>" +
            " <button type=\"submit\" form=\"languageCreateForm\" class=\"btn btn-primary\"><i class=\"bx bx-save me-1\"></i> " + saveText + "</button>")
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form id="languageCreateForm" asp-area="Admin" asp-controller="Localization" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <partial name="_CreateOrUpdate" model="Model" />
        </form>
    </div>
</div>

