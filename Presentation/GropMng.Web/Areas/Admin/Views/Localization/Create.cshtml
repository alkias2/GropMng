@using GropMng.Web.Framework.TagHelpers.Admin
@model GropMng.Web.Areas.Admin.Models.Localization.LanguageModel
@{
    ViewData["Title"] = T("admin.localization.language.create");
    GropHtml.SetActiveMenuItemSystemName("Localization");

    var listUrl = Url.Action("List", "Localization", new { area = "Admin" })!;
}

<grop-admin-page-header
    title="@T("admin.localization.language.create")"
    breadcrumbs="@(new List<AdminBreadcrumbItemModel>
    {
        new() { Text = T("common.dashboard"), Url = Url.Action("Index", "Home", new { area = "" }) },
        new() { Text = T("admin.localization.languages.title"), Url = listUrl },
        new() { Text = T("admin.localization.language.create") }
    })">
    <grop-header-button href="@listUrl"
                        text="@T("common.cancel")"
                        icon="bx bx-arrow-back"
                        css-class="btn btn-label-secondary" />
    <grop-header-button form="languageCreateForm"
                        type="submit"
                        text="@T("common.save")"
                        icon="bx bx-save"
                        css-class="btn btn-primary" />
</grop-admin-page-header>

@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form id="languageCreateForm" asp-area="Admin" asp-controller="Localization" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <partial name="_CreateOrUpdate" model="Model" />
        </form>
    </div>
</div>

