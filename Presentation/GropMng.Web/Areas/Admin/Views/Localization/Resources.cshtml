@model GropMng.Web.Areas.Admin.Models.Localization.LocaleResourceSearchModel
@using GropMng.Web.Areas.Admin.Models.Localization
@using GropMng.Web.Framework.Models.DataTables
@using GropMng.Web.Framework.TagHelpers.Admin
@using Microsoft.AspNetCore.Routing
@{
    ViewData["Title"] = T("admin.localization.resources.title");
    GropHtml.SetActiveMenuItemSystemName("Localization");
}

<grop-admin-page-header
    title="@(string.IsNullOrWhiteSpace(Model.LanguageName) ? T("admin.localization.resources.title") : $"{T("admin.localization.resources.title")} - {Model.LanguageName}")"
    breadcrumbs="@(new List<AdminBreadcrumbItemModel>
    {
        new() { Text = T("common.dashboard"), Url = Url.Action("Index", "Home", new { area = "" }) },
        new() { Text = T("admin.localization.languages.title"), Url = Url.Action("List", "Localization", new { area = "Admin" }) },
        new() { Text = T("admin.localization.resources.title") }
    })">
</grop-admin-page-header>

@await Html.PartialAsync("Notifications")

@Html.AntiForgeryToken()

<input asp-for="LanguageId" type="hidden" />

<div class="card mb-4">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 me-auto">@T("common.search")</h5>
        <button id="btnAddResource" class="btn btn-success btn-sm me-2">
            <i class="bx bx-plus me-1"></i> @T("common.create")
        </button>
        <button id="btnApplyFilters" class="btn btn-primary btn-sm">
            <i class="bx bx-filter-alt me-1"></i> @T("common.apply")
        </button>
        <button id="btnClearFilters" class="btn btn-outline-secondary btn-sm ms-2">
            <i class="bx bx-x me-1"></i> @T("common.clear")
        </button>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <grop-label asp-for="ResourceName" />
                <input asp-for="ResourceName" class="form-control" />
            </div>
            <div class="col-md-6">
                <grop-label asp-for="ResourceValue" />
                <input asp-for="ResourceValue" class="form-control" />
            </div>
        </div>
    </div>
</div>

<div id="addResourcePanel" class="card mb-4 d-none">
    <div class="card-header">
        <h5 class="card-title mb-0">@T("common.create")</h5>
    </div>
    <div class="card-body">
        <div id="addResourceErrors" class="alert alert-danger d-none" role="alert"></div>
        <div class="row g-3">
            <div class="col-md-5">
                <label class="form-label" for="addResourceName">@T("admin.localization.resource.fields.name")</label>
                <input type="text" id="addResourceName" class="form-control" maxlength="400" />
            </div>
            <div class="col-md-5">
                <label class="form-label" for="addResourceValue">@T("admin.localization.resource.fields.value")</label>
                <input type="text" id="addResourceValue" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button id="btnSaveNewResource" class="btn btn-primary btn-sm">
                    <i class="bx bx-save me-1"></i> @T("common.save")
                </button>
                <button id="btnCancelNewResource" class="btn btn-outline-secondary btn-sm">
                    @T("common.cancel")
                </button>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("Table", new GropDataTablesModel
{
    Name = "localeResourcesTable",
    UrlRead = new GropDataUrl("LocaleResourceList", "Localization", new RouteValueDictionary(new { area = "Admin" })),
    SearchButtonId = "btnApplyFilters",
    ClearButtonId = "btnClearFilters",
    ClearFilterIds = [nameof(LocaleResourceSearchModel.ResourceName), nameof(LocaleResourceSearchModel.ResourceValue)],
    Length = Model.PageSize,
    LengthMenu = [10, 25, 50, 100],
    Filters =
    [
        new GropFilterParameter(nameof(LocaleResourceSearchModel.LanguageId)),
        new GropFilterParameter(nameof(LocaleResourceSearchModel.ResourceName)),
        new GropFilterParameter(nameof(LocaleResourceSearchModel.ResourceValue))
    ],
    ColumnCollection =
    [
        new GropColumnProperty("id")
        {
            Title = "ID",
            Width = "80px"
        },
        new GropColumnProperty("resourceName")
        {
            Title = T("admin.localization.resource.fields.name")
        },
        new GropColumnProperty("resourceValue")
        {
            Title = T("admin.localization.resource.fields.value")
        },
        new GropColumnProperty("id")
        {
            Title = T("common.actions"),
            Width = "120px",
            Render = new RenderCustom("localeResource_renderActions"),
            Orderable = false,
            Searchable = false
        }
    ]
})

@section Vendors {
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
}

@section Scripts {
    <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
    <script>
        window.localeResourceConfig = {
            languageId: @Model.LanguageId,
            urlAdd: '@Url.Action("AddLocaleResource", "Localization", new { area = "Admin" })',
            urlUpdate: '@Url.Action("UpdateLocaleResource", "Localization", new { area = "Admin" })',
            urlDelete: '@Url.Action("DeleteLocaleResource", "Localization", new { area = "Admin" })',
            tableSelector: '#localeResourcesTable',
            texts: {
                edit: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.edit"))),
                delete: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.delete"))),
                save: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.save"))),
                cancel: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.cancel")))
            }
        };
    </script>
    <script src="~/js-custom/admin.locale-resources.js"></script>
}

