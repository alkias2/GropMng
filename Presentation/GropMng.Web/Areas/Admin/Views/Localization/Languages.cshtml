@model IReadOnlyList<GropMng.Core.Domain.Localization.Language>
@{
    ViewData["Title"] = T("admin.localization.languages.title");
    ViewData["ActiveMenu"] = "Localization";

    var titleText = (string)ViewData["Title"]!;
    var dashboardText = T("common.dashboard");

    var headerModel = new AdminPageHeaderModel
    {
        Title = titleText,
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = dashboardText, Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = titleText }
        }
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="d-flex justify-content-end mb-4">
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Localization" asp-action="CreateLanguage">
        <i class="bx bx-plus me-1"></i> @T("admin.localization.language.create")
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>@T("admin.localization.language.fields.name")</th>
                    <th>@T("admin.localization.language.fields.culture")</th>
                    <th>@T("admin.localization.language.fields.seocode")</th>
                    <th>@T("admin.localization.language.fields.published")</th>
                    <th>@T("admin.localization.language.fields.displayorder")</th>
                    <th class="text-center">@T("common.actions")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var language in Model)
                {
                    <tr>
                        <td>@language.Id</td>
                        <td>@language.Name</td>
                        <td>@language.LanguageCulture</td>
                        <td>@language.UniqueSeoCode</td>
                        <td>@(language.Published ? T("common.yes") : T("common.no"))</td>
                        <td>@language.DisplayOrder</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-outline-primary me-1"
                               asp-area="Admin"
                               asp-controller="Localization"
                               asp-action="EditLanguage"
                               asp-route-id="@language.Id">
                                <i class="bx bx-edit"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-info me-1"
                               asp-area="Admin"
                               asp-controller="Localization"
                               asp-action="Resources"
                               asp-route-languageId="@language.Id">
                                <i class="bx bx-list-ul"></i>
                            </a>
                            <form class="d-inline" asp-area="Admin" asp-controller="Localization" asp-action="DeleteLanguage" method="post"
                                  data-grop-delete="true"
                                  data-confirm-icon="warning"
                                  data-confirm-title="@T("admin.localization.language.delete")"
                                  data-confirm-text="@T("admin.localization.language.delete.confirm")"
                                  data-confirm-button-text="@T("common.delete")"
                                  data-cancel-button-text="@T("common.cancel")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@language.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bx bx-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

