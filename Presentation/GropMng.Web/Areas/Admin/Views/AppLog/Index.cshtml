@model GropMng.Web.Areas.Admin.Models.Logging.AppLogSearchModel
@{
    ViewData["Title"] = "Application Logs";
    ViewData["ActiveMenu"] = "AppLogs";

    var headerModel = new AdminPageHeaderModel
    {
        Title = "Application Logs",
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = "Dashboard", Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = "App Logs" }
        }
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)

<div class="d-flex justify-content-end gap-2 mb-4">
    <button id="btnDeleteSelected" type="button" class="btn btn-outline-danger" disabled>
        <i class="bx bx-trash me-1"></i> Delete Selected (<span id="selectedCount">0</span>)
    </button>

    <form asp-area="Admin" asp-controller="AppLog" asp-action="DeleteAll" method="post"
          data-grop-delete="true"
          data-confirm-icon="warning"
          data-confirm-title="Delete all log entries"
          data-confirm-text="This action will permanently delete all log entries."
          data-confirm-button-text="Delete all"
          data-cancel-button-text="Cancel">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">
            <i class="bx bx-trash me-1"></i> Delete All
        </button>
    </form>
</div>

<!-- Filter card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 me-auto">Filters</h5>
        <button id="btnApplyFilters" class="btn btn-primary btn-sm">
            <i class="bx bx-filter-alt me-1"></i> Apply
        </button>
        <button id="btnClearFilters" class="btn btn-outline-secondary btn-sm ms-2">
            <i class="bx bx-x me-1"></i> Clear
        </button>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4 col-sm-6">
                <label class="form-label" for="levelFilter">Log Level</label>
                <select id="levelFilter" class="form-select">
                    <option value="">All Levels</option>
                    <option value="Trace">Trace</option>
                    <option value="Debug">Debug</option>
                    <option value="Information">Information</option>
                    <option value="Warning">Warning</option>
                    <option value="Error">Error</option>
                    <option value="Critical">Critical</option>
                </select>
            </div>
            <div class="col-md-4 col-sm-6">
                <label class="form-label" for="fromDateFilter">From Date</label>
                <input id="fromDateFilter" type="text" class="form-control flatpickr-date"
                       placeholder="YYYY-MM-DD" autocomplete="off" />
            </div>
            <div class="col-md-4 col-sm-6">
                <label class="form-label" for="toDateFilter">To Date</label>
                <input id="toDateFilter" type="text" class="form-control flatpickr-date"
                       placeholder="YYYY-MM-DD" autocomplete="off" />
            </div>
        </div>
    </div>
</div>

<!-- DataTable card -->
<div class="card">
    <div class="card-datatable table-responsive">
        <table id="appLogsTable" class="table table-hover">
            <thead>
                <tr>
                    <th class="text-center" style="width:44px;">
                        <input id="selectAllVisible" type="checkbox" class="form-check-input" title="Select all visible" />
                    </th>
                    <th>ID</th>
                    <th>Level</th>
                    <th>Category</th>
                    <th>Message</th>
                    <th>Timestamp</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Vendors {
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section Scripts {
    <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
    <script src="~/vendor/libs/flatpickr/flatpickr.js"></script>

    <script>
        'use strict';

        // ── Date pickers ─────────────────────────────────────────────────────
        flatpickr('#fromDateFilter', { dateFormat: 'Y-m-d', allowInput: true });
        flatpickr('#toDateFilter',   { dateFormat: 'Y-m-d', allowInput: true });

        // ── Level badge colours ───────────────────────────────────────────────
        const levelBadge = {
            Trace:       'secondary',
            Debug:       'info',
            Information: 'primary',
            Warning:     'warning',
            Error:       'danger',
            Critical:    'danger'
        };

        function renderLevel(level) {
            const colour = levelBadge[level] ?? 'secondary';
            return `<span class="badge bg-label-${colour}">${level ?? ''}</span>`;
        }

        // ── DataTable ─────────────────────────────────────────────────────────
        const listUrl  = '@Url.Action("List",    "AppLog", new { area = "Admin" })';
        const detailUrl= '@Url.Action("Details", "AppLog", new { area = "Admin" })';
        const deleteUrl= '@Url.Action("Delete",  "AppLog", new { area = "Admin" })';
        const deleteSelectedUrl = '@Url.Action("DeleteSelected", "AppLog", new { area = "Admin" })';
        const token    = $('input[name="__RequestVerificationToken"]').val();
        const selectedIds = new Set();

        function updateSelectionUi() {
            $('#selectedCount').text(selectedIds.size);
            $('#btnDeleteSelected').prop('disabled', selectedIds.size === 0);
            updateSelectAllVisibleState();
        }

        function updateSelectAllVisibleState() {
            const visibleCheckboxes = $('#appLogsTable tbody .row-selector');
            const totalVisible = visibleCheckboxes.length;

            if (totalVisible === 0) {
                $('#selectAllVisible').prop('checked', false).prop('indeterminate', false);
                return;
            }

            const checkedVisible = visibleCheckboxes.filter(':checked').length;
            $('#selectAllVisible')
                .prop('checked', checkedVisible === totalVisible)
                .prop('indeterminate', checkedVisible > 0 && checkedVisible < totalVisible);
        }

        function reapplyRowSelections() {
            $('#appLogsTable tbody .row-selector').each(function () {
                const id = Number($(this).data('id'));
                $(this).prop('checked', selectedIds.has(id));
            });

            updateSelectionUi();
        }

        const table = $('#appLogsTable').DataTable({
            processing : true,
            serverSide : true,
            responsive : true,
            ajax: {
                url : listUrl,
                type: 'POST',
                data: function (d) {
                    d.level    = $('#levelFilter').val();
                    d.fromDate = $('#fromDateFilter').val();
                    d.toDate   = $('#toDateFilter').val();
                }
            },
            columns: [
                {
                    data      : 'id',
                    orderable : false,
                    searchable: false,
                    width     : '44px',
                    className : 'text-center',
                    render    : function (id) {
                        return `<input type="checkbox" class="form-check-input row-selector" data-id="${id}" />`;
                    }
                },
                { data: 'id',        width: '60px' },
                {
                    data: 'level',
                    width: '110px',
                    render: function (data) { return renderLevel(data); }
                },
                { data: 'category',  className: 'text-truncate', width: '200px' },
                { data: 'message',   className: 'text-truncate', width: '300px' },
                {
                    data: 'timestamp',
                    width: '160px',
                    render: function (data) {
                        return data ? new Date(data).toLocaleString() : '';
                    }
                },
                {
                    data      : 'id',
                    orderable : false,
                    width     : '120px',
                    className : 'text-center',
                    render    : function (id) {
                        return `<a class="btn btn-sm btn-icon btn-outline-primary me-1"
                                   href="${detailUrl}/${id}" title="Details">
                                    <i class="bx bx-show"></i>
                                </a>
                                <button class="btn btn-sm btn-icon btn-outline-danger btn-delete"
                                        data-id="${id}" title="Delete">
                                    <i class="bx bx-trash"></i>
                                </button>`;
                    }
                }
            ],
            order: [[5, 'desc']],
            language: {
                processing: '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>'
            }
        });

        table.on('draw', function () {
            reapplyRowSelections();
        });

        // ── Filter buttons ────────────────────────────────────────────────────
        $('#btnApplyFilters').on('click', function () { table.ajax.reload(); });

        $('#btnClearFilters').on('click', function () {
            document.getElementById('levelFilter').value = '';
            flatpickr('#fromDateFilter').clear();
            flatpickr('#toDateFilter').clear();
            table.ajax.reload();
        });

        // ── Row selection and bulk actions ───────────────────────────────────
        $('#appLogsTable').on('change', '.row-selector', function () {
            const id = Number($(this).data('id'));
            if ($(this).is(':checked'))
                selectedIds.add(id);
            else
                selectedIds.delete(id);

            updateSelectionUi();
        });

        $('#selectAllVisible').on('change', function () {
            const shouldCheck = $(this).is(':checked');

            $('#appLogsTable tbody .row-selector').each(function () {
                const id = Number($(this).data('id'));
                $(this).prop('checked', shouldCheck);

                if (shouldCheck)
                    selectedIds.add(id);
                else
                    selectedIds.delete(id);
            });

            updateSelectionUi();
        });

        $('#btnDeleteSelected').on('click', async function () {
            if (selectedIds.size === 0) return;

            const selectedArray = Array.from(selectedIds);
            const confirmationText = `This action will permanently delete ${selectedArray.length} selected log entr${selectedArray.length === 1 ? 'y' : 'ies'}.`;
            const confirmed = await window.GropSwal.confirm({
                icon: 'warning',
                title: 'Delete selected logs',
                text: confirmationText,
                confirmButtonText: 'Delete selected',
                cancelButtonText: 'Cancel'
            });
            if (!confirmed) return;

            $.ajax({
                url: deleteSelectedUrl,
                type: 'POST',
                traditional: true,
                data: {
                    selectedIds: selectedArray,
                    __RequestVerificationToken: token
                },
                success: function () {
                    selectedIds.clear();
                    $('#selectAllVisible').prop('checked', false).prop('indeterminate', false);
                    table.ajax.reload(null, false);
                    window.GropSwal.notify({ icon: 'success', title: 'Selected log entries were deleted.' });
                },
                error: function (xhr) {
                    const msg = xhr?.responseJSON?.message ?? 'Failed to delete selected log entries.';
                    window.GropSwal.alert({ icon: 'error', title: 'Delete failed', text: msg });
                }
            });
        });

        // ── Row delete ────────────────────────────────────────────────────────
        $('#appLogsTable').on('click', '.btn-delete', async function () {
            const id = $(this).data('id');
            const confirmed = await window.GropSwal.confirm({
                icon: 'warning',
                title: 'Delete log entry',
                text: 'This log entry will be permanently deleted.',
                confirmButtonText: 'Delete',
                cancelButtonText: 'Cancel'
            });
            if (!confirmed) return;

            $.ajax({
                url   : deleteUrl,
                type  : 'POST',
                data  : { id: id, __RequestVerificationToken: token },
                success: function () {
                    selectedIds.delete(Number(id));
                    table.ajax.reload(null, false);
                    window.GropSwal.notify({ icon: 'success', title: 'Log entry deleted.' });
                },
                error  : function () {
                    window.GropSwal.alert({ icon: 'error', title: 'Delete failed', text: 'Failed to delete the log entry.' });
                }
            });
        });

        updateSelectionUi();
    </script>
}
