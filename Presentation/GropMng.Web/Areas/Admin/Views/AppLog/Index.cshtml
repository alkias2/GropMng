@model GropMng.Web.Areas.Admin.Models.Logging.AppLogSearchModel
@{
    var titleText = T("admin.applog.title");
    var dashboardText = T("common.dashboard");
    var breadcrumbText = T("admin.applog.breadcrumb");
    var deleteSelectedText = T("admin.applog.delete.selected");
    var deleteAllText = T("admin.applog.delete.all");
    var deleteAllTitleText = T("admin.applog.delete.all.title");
    var deleteAllConfirmText = T("admin.applog.delete.all.confirm");
    var deleteAllConfirmButtonText = T("admin.applog.delete.all.confirmbutton");
    var cancelText = T("common.cancel");
    var filtersText = T("common.filters");
    var applyText = T("common.apply");
    var clearText = T("common.clear");
    var levelText = T("admin.applog.fields.level");
    var allLevelsText = T("admin.applog.filters.alllevels");
    var fromDateText = T("common.fromdate");
    var toDateText = T("common.todate");
    var idText = T("admin.applog.fields.id");
    var categoryText = T("admin.applog.fields.category");
    var messageText = T("admin.applog.fields.message");
    var timestampText = T("admin.applog.fields.timestamp");
    var actionsText = T("common.actions");
    var selectAllVisibleText = T("admin.applog.grid.selectallvisible");

    var tableModel = new AdminDataTableModel
    {
        TableId = "appLogsTable",
        Columns = new List<AdminDataTableColumnModel>
        {
            new()
            {
                Title = $"<input id=\"selectAllVisible\" type=\"checkbox\" class=\"form-check-input\" title=\"{selectAllVisibleText}\" />",
                CssClass = "text-center",
                Style = "width:44px;"
            },
            new() { Title = idText },
            new() { Title = levelText },
            new() { Title = categoryText },
            new() { Title = messageText },
            new() { Title = timestampText },
            new() { Title = actionsText, CssClass = "text-center" }
        }
    };

    ViewData["Title"] = titleText;
    ViewData["ActiveMenu"] = "AppLogs";

    var headerModel = new AdminPageHeaderModel
    {
        Title = titleText,
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = dashboardText, Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = breadcrumbText }
        }
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)

<div class="d-flex justify-content-end gap-2 mb-4">
    <button id="btnDeleteSelected" type="button" class="btn btn-outline-danger" disabled>
        <i class="bx bx-trash me-1"></i> @deleteSelectedText (<span id="selectedCount">0</span>)
    </button>

    <form asp-area="Admin" asp-controller="AppLog" asp-action="DeleteAll" method="post"
          data-grop-delete="true"
          data-confirm-icon="warning"
          data-confirm-title="@deleteAllTitleText"
          data-confirm-text="@deleteAllConfirmText"
          data-confirm-button-text="@deleteAllConfirmButtonText"
          data-cancel-button-text="@cancelText">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">
            <i class="bx bx-trash me-1"></i> @deleteAllText
        </button>
    </form>
</div>

<!-- Filter card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 me-auto">@filtersText</h5>
        <button id="btnApplyFilters" class="btn btn-primary btn-sm">
            <i class="bx bx-filter-alt me-1"></i> @applyText
        </button>
        <button id="btnClearFilters" class="btn btn-outline-secondary btn-sm ms-2">
            <i class="bx bx-x me-1"></i> @clearText
        </button>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4 col-sm-6">
                <label class="form-label" for="levelFilter">@levelText</label>
                <select id="levelFilter" class="form-select">
                    <option value="">@allLevelsText</option>
                    <option value="Trace">@T("admin.applog.level.trace")</option>
                    <option value="Debug">@T("admin.applog.level.debug")</option>
                    <option value="Information">@T("admin.applog.level.information")</option>
                    <option value="Warning">@T("admin.applog.level.warning")</option>
                    <option value="Error">@T("admin.applog.level.error")</option>
                    <option value="Critical">@T("admin.applog.level.critical")</option>
                </select>
            </div>
            <div class="col-md-4 col-sm-6">
                <label class="form-label" for="fromDateFilter">@fromDateText</label>
                <input id="fromDateFilter" type="text" class="form-control flatpickr-date"
                       placeholder="YYYY-MM-DD" autocomplete="off" />
            </div>
            <div class="col-md-4 col-sm-6">
                <label class="form-label" for="toDateFilter">@toDateText</label>
                <input id="toDateFilter" type="text" class="form-control flatpickr-date"
                       placeholder="YYYY-MM-DD" autocomplete="off" />
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("Table", tableModel)

<form id="antiForgeryForm" method="post">
    @Html.AntiForgeryToken()
</form>

@section Vendors {
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section Scripts {
    <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
    <script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
    <script src="~/js/admin.table.js" asp-append-version="true"></script>

    <script>
        'use strict';

        // ── Date pickers ─────────────────────────────────────────────────────
        flatpickr('#fromDateFilter', { dateFormat: 'Y-m-d', allowInput: true });
        flatpickr('#toDateFilter',   { dateFormat: 'Y-m-d', allowInput: true });

        const currentCulture = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(GetCurrentCultureCode() ?? "en-US"));
        const localizedTexts = {
            details: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.details"))),
            cancel: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.cancel"))),
            delete: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.delete"))),
            processing: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.processing"))),
            lengthMenu: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.lengthmenu"))),
            zeroRecords: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.zerorecords"))),
            emptyTable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.emptytable"))),
            info: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.info"))),
            infoEmpty: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.infoempty"))),
            infoFiltered: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.infofiltered"))),
            search: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.search"))),
            first: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.paginate.first"))),
            last: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.paginate.last"))),
            next: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.paginate.next"))),
            previous: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.datatable.paginate.previous"))),
            deleteSelectedTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.selected.title"))),
            deleteSelectedConfirmSingle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.selected.confirm.single"))),
            deleteSelectedConfirmMultiple: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.selected.confirm"))),
            deleteSelectedConfirmButton: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.selected.confirmbutton"))),
            deleteSelectedSuccess: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.selected.success"))),
            deleteSelectedError: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.selected.error"))),
            deleteSingleTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.single.title"))),
            deleteSingleConfirm: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.single.confirm"))),
            deleteSingleSuccess: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.single.success"))),
            deleteSingleError: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.delete.single.error")))
        };
        const levelTexts = {
            Trace: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.level.trace"))),
            Debug: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.level.debug"))),
            Information: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.level.information"))),
            Warning: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.level.warning"))),
            Error: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.level.error"))),
            Critical: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.applog.level.critical")))
        };

        // ── Level badge colours ───────────────────────────────────────────────
        const levelBadge = {
            Trace:       'secondary',
            Debug:       'info',
            Information: 'primary',
            Warning:     'warning',
            Error:       'danger',
            Critical:    'danger'
        };

        function renderLevel(level) {
            const colour = levelBadge[level] ?? 'secondary';
            const localizedLevel = window.GropAdminTable.localizeByMap(level, levelTexts, '');
            return `<span class="badge bg-label-${colour}">${localizedLevel}</span>`;
        }

        // ── DataTable ─────────────────────────────────────────────────────────
        const listUrl  = '@Url.Action("List",    "AppLog", new { area = "Admin" })';
        const detailUrl= '@Url.Action("Details", "AppLog", new { area = "Admin" })';
        const deleteUrl= '@Url.Action("Delete",  "AppLog", new { area = "Admin" })';
        const deleteSelectedUrl = '@Url.Action("DeleteSelected", "AppLog", new { area = "Admin" })';
        const token    = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();
        const selectedIds = new Set();

        function updateSelectionUi() {
            $('#selectedCount').text(selectedIds.size);
            $('#btnDeleteSelected').prop('disabled', selectedIds.size === 0);
            updateSelectAllVisibleState();
        }

        function updateSelectAllVisibleState() {
            const visibleCheckboxes = $('#appLogsTable tbody .row-selector');
            const totalVisible = visibleCheckboxes.length;

            if (totalVisible === 0) {
                $('#selectAllVisible').prop('checked', false).prop('indeterminate', false);
                return;
            }

            const checkedVisible = visibleCheckboxes.filter(':checked').length;
            $('#selectAllVisible')
                .prop('checked', checkedVisible === totalVisible)
                .prop('indeterminate', checkedVisible > 0 && checkedVisible < totalVisible);
        }

        function reapplyRowSelections() {
            $('#appLogsTable tbody .row-selector').each(function () {
                const id = Number($(this).data('id'));
                $(this).prop('checked', selectedIds.has(id));
            });

            updateSelectionUi();
        }

        const table = window.GropAdminTable.createDataTable('#appLogsTable', {
            localizedTexts: localizedTexts,
            ajax: {
                url : listUrl,
                type: 'POST',
                data: function (d) {
                    d.level    = $('#levelFilter').val();
                    d.fromDate = $('#fromDateFilter').val();
                    d.toDate   = $('#toDateFilter').val();
                }
            },
            columns: [
                {
                    data      : 'id',
                    orderable : false,
                    searchable: false,
                    width     : '44px',
                    className : 'text-center',
                    render    : function (id) {
                        return `<input type="checkbox" class="form-check-input row-selector" data-id="${id}" />`;
                    }
                },
                { data: 'id',        width: '60px' },
                {
                    data: 'level',
                    width: '110px',
                    render: function (data) { return renderLevel(data); }
                },
                { data: 'category',  className: 'text-truncate', width: '200px' },
                { data: 'message',   className: 'text-truncate', width: '300px' },
                {
                    data: 'timestamp',
                    width: '160px',
                    render: function (data) {
                        return data ? new Date(data).toLocaleString() : '';
                    }
                },
                {
                    data      : 'id',
                    orderable : false,
                    width     : '120px',
                    className : 'text-center',
                    render    : function (id) {
                        return `<a class="btn btn-sm btn-icon btn-outline-primary me-1"
                                   href="${detailUrl}/${id}" title="${localizedTexts.details}">
                                    <i class="bx bx-show"></i>
                                </a>
                                <button class="btn btn-sm btn-icon btn-outline-danger btn-delete"
                                        data-id="${id}" title="${localizedTexts.delete}">
                                    <i class="bx bx-trash"></i>
                                </button>`;
                    }
                }
            ],
            order: [[5, 'desc']]
        });

        table.on('draw', function () {
            reapplyRowSelections();
        });

        // ── Filter buttons ────────────────────────────────────────────────────
        window.GropAdminTable.bindFilterButtons(table, {
            applyButtonSelector: '#btnApplyFilters',
            clearButtonSelector: '#btnClearFilters',
            clearCallback: function () {
                document.getElementById('levelFilter').value = '';
                flatpickr('#fromDateFilter').clear();
                flatpickr('#toDateFilter').clear();
            }
        });

        // ── Row selection and bulk actions ───────────────────────────────────
        $('#appLogsTable').on('change', '.row-selector', function () {
            const id = Number($(this).data('id'));
            if ($(this).is(':checked'))
                selectedIds.add(id);
            else
                selectedIds.delete(id);

            updateSelectionUi();
        });

        $('#selectAllVisible').on('change', function () {
            const shouldCheck = $(this).is(':checked');

            $('#appLogsTable tbody .row-selector').each(function () {
                const id = Number($(this).data('id'));
                $(this).prop('checked', shouldCheck);

                if (shouldCheck)
                    selectedIds.add(id);
                else
                    selectedIds.delete(id);
            });

            updateSelectionUi();
        });

        $('#btnDeleteSelected').on('click', async function () {
            if (selectedIds.size === 0) return;

            const selectedArray = Array.from(selectedIds);
            const confirmationText = selectedArray.length === 1
                ? localizedTexts.deleteSelectedConfirmSingle
                : window.GropAdminTable.formatString(localizedTexts.deleteSelectedConfirmMultiple, selectedArray.length);
            const confirmed = await window.GropSwal.confirm({
                icon: 'warning',
                title: localizedTexts.deleteSelectedTitle,
                text: confirmationText,
                confirmButtonText: localizedTexts.deleteSelectedConfirmButton,
                cancelButtonText: localizedTexts.cancel
            });
            if (!confirmed) return;

            $.ajax({
                url: deleteSelectedUrl,
                type: 'POST',
                traditional: true,
                data: {
                    selectedIds: selectedArray,
                    __RequestVerificationToken: token
                },
                success: function () {
                    selectedIds.clear();
                    $('#selectAllVisible').prop('checked', false).prop('indeterminate', false);
                    table.ajax.reload(null, false);
                    window.GropSwal.notify({ icon: 'success', title: localizedTexts.deleteSelectedSuccess });
                },
                error: function (xhr) {
                    const msg = xhr?.responseJSON?.message ?? localizedTexts.deleteSelectedError;
                    window.GropSwal.alert({ icon: 'error', title: localizedTexts.deleteSelectedTitle, text: msg });
                }
            });
        });

        // ── Row delete ────────────────────────────────────────────────────────
        $('#appLogsTable').on('click', '.btn-delete', async function () {
            const id = $(this).data('id');
            const confirmed = await window.GropSwal.confirm({
                icon: 'warning',
                title: localizedTexts.deleteSingleTitle,
                text: localizedTexts.deleteSingleConfirm,
                confirmButtonText: localizedTexts.delete,
                cancelButtonText: localizedTexts.cancel
            });
            if (!confirmed) return;

            $.ajax({
                url   : deleteUrl,
                type  : 'POST',
                data  : { id: id, __RequestVerificationToken: token },
                success: function () {
                    selectedIds.delete(Number(id));
                    table.ajax.reload(null, false);
                    window.GropSwal.notify({ icon: 'success', title: localizedTexts.deleteSingleSuccess });
                },
                error  : function () {
                    window.GropSwal.alert({ icon: 'error', title: localizedTexts.deleteSingleTitle, text: localizedTexts.deleteSingleError });
                }
            });
        });

        updateSelectionUi();
    </script>
}
