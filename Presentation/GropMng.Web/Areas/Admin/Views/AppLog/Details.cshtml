@using GropMng.Core.Domain.Logging
@model AppLog
@{
    ViewData["Title"] = "Log Entry Details";

    var levelBadge = Model.Level switch
    {
        "Trace"       => "secondary",
        "Debug"       => "info",
        "Information" => "primary",
        "Warning"     => "warning",
        "Error"       => "danger",
        "Critical"    => "danger",
        _             => "secondary"
    };
}

<!-- Page header -->
<div class="row">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between py-3 mb-4">
            <div>
                <h4 class="fw-bold mb-1">Log Entry Details</h4>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb breadcrumb-style1 mb-0">
                        <li class="breadcrumb-item">
                            <a href="@Url.Action("Index", "Home", new { area = "" })">Dashboard</a>
                        </li>
                        <li class="breadcrumb-item">
                            <a href="@Url.Action("Index", "AppLog", new { area = "Admin" })">App Logs</a>
                        </li>
                        <li class="breadcrumb-item active">Details #@Model.Id</li>
                    </ol>
                </nav>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary"
                   href="@Url.Action("Index", "AppLog", new { area = "Admin" })">
                    <i class="bx bx-arrow-back me-1"></i> Back to List
                </a>
                <form asp-area="Admin" asp-controller="AppLog" asp-action="Delete" method="post"
                      onsubmit="return confirm('Delete this log entry?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bx bx-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Details card -->
<div class="row">
    <div class="col-lg-8 col-12">
        <div class="card">
            <div class="card-header d-flex align-items-center">
                <h5 class="card-title mb-0 me-auto">Log #@Model.Id</h5>
                <span class="badge bg-label-@levelBadge fs-6">@Model.Level</span>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Timestamp</dt>
                    <dd class="col-sm-9">@Model.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>

                    <dt class="col-sm-3 text-muted">Category</dt>
                    <dd class="col-sm-9"><code>@Model.Category</code></dd>

                    <dt class="col-sm-3 text-muted">Message</dt>
                    <dd class="col-sm-9">@Model.Message</dd>

                    @if (Model.EventId.HasValue)
                    {
                        <dt class="col-sm-3 text-muted">Event ID</dt>
                        <dd class="col-sm-9">@Model.EventId</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.RequestPath))
                    {
                        <dt class="col-sm-3 text-muted">Request Path</dt>
                        <dd class="col-sm-9"><code>@Model.RequestPath</code></dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.ExceptionType))
                    {
                        <dt class="col-sm-3 text-muted">Exception Type</dt>
                        <dd class="col-sm-9"><span class="badge bg-label-danger">@Model.ExceptionType</span></dd>
                    }
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StackTrace))
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Stack Trace</h5>
                </div>
                <div class="card-body p-0">
                    <pre class="p-3 mb-0 rounded-bottom" style="font-size:0.8rem;max-height:400px;overflow-y:auto;white-space:pre-wrap;word-break:break-all;">@Model.StackTrace</pre>
                </div>
            </div>
        }
    </div>
</div>
