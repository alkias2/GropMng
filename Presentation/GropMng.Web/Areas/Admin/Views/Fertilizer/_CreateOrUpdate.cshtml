@model GropMng.Web.Areas.Admin.Models.Fertilizer.FertilizerModel

@{
    var localizedFertilizerTypes = Model.AvailableFertilizerTypes
        .Select(item => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = item.Value,
            Text = string.IsNullOrWhiteSpace(item.Value)
                ? T("common.none")
                : T($"admin.fertilizer.fertilizertype.{item.Value.ToLowerInvariant()}"),
            Selected = item.Selected
        })
        .ToList();

    var localizedApplicationMethods = Model.AvailableApplicationMethods
        .Select(item => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = item.Value,
            Text = string.IsNullOrWhiteSpace(item.Value)
                ? T("common.none")
                : T($"admin.fertilizer.applicationmethod.{item.Value.ToLowerInvariant()}"),
            Selected = item.Selected
        })
        .ToList();
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-md-6">
        <grop-label asp-for="Name" />
        <grop-editor asp-for="Name" asp-required="true" />
        <span class="text-danger" asp-validation-for="Name"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="Brand" />
        <grop-editor asp-for="Brand" />
        <span class="text-danger" asp-validation-for="Brand"></span>
    </div>

    <div class="col-md-4">
        <grop-label asp-for="FertilizerType" />
        <grop-select asp-for="FertilizerType" asp-items="localizedFertilizerTypes" />
        <span class="text-danger" asp-validation-for="FertilizerType"></span>
    </div>

    <div class="col-md-4">
        <grop-label asp-for="ApplicationMethod" />
        <grop-select asp-for="ApplicationMethod" asp-items="localizedApplicationMethods" />
        <span class="text-danger" asp-validation-for="ApplicationMethod"></span>
    </div>

    <div class="col-md-4">
        <grop-label asp-for="NpkRatio" />
        <grop-editor asp-for="NpkRatio" />
        <span class="text-danger" asp-validation-for="NpkRatio"></span>
    </div>

    <div class="col-md-12">
        <div class="form-check form-switch mt-2">
            <input class="form-check-input" type="checkbox" asp-for="IsOrganic" />
            <grop-label asp-for="IsOrganic" css-class="form-check-label" />
        </div>
    </div>

    <div class="col-md-12">
        <grop-label asp-for="Notes" />
        <grop-textarea asp-for="Notes" asp-rows="3" />
        <span class="text-danger" asp-validation-for="Notes"></span>
    </div>
</div>
