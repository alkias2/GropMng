@model IList<GropMng.Web.Areas.Admin.Models.Roles.PermissionGroupModel>

<div class="row g-4">
    @foreach (var group in Model)
    {
        <div class="col-xl-6 col-lg-12">
            <div class="card border shadow-none h-100">
                <div class="card-header pb-2">
                    <h5 class="card-title mb-0">@group.Category</h5>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var permission in group.Permissions)
                        {
                            <div class="col-12">
                                <label class="form-check">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissionSystemNames" value="@permission.SystemName" checked="@permission.Selected" />
                                    <span class="form-check-label">
                                        <span class="fw-medium">@permission.Name</span><br />
                                        <small class="text-muted">@permission.SystemName</small>
                                    </span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
