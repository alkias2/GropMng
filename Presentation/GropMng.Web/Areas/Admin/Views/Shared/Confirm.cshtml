@{
    var selector = ViewData["ConfirmSelector"]?.ToString() ?? "form[data-grop-confirm='true'], form[data-grop-delete='true']";
}

<script>
    window.gropCommonTexts = {
        deleteTitle:      @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.confirm.delete.title"))),
        deleteText:       @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.confirm.delete.text"))),
        deleteItemsText:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.confirm.delete.items"))),
        deleteButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.delete"))),
        cancelButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.cancel"))),
        okButtonText:     @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.ok"))),
        yesButtonText:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.yes"))),
        noButtonText:     @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.no"))),
        loadingText:      @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.loading"))),
        networkErrorText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.networkerror")))
    };
    window.GropSwal?.bindConfirmForms(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(selector)));
</script>