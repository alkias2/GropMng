@model GropMng.Web.Areas.Admin.Models.Common.AdminPageHeaderModel
@using Microsoft.AspNetCore.Html

<div class="row">
    <div class="col-12">
        <!-- Breadcrumb -->
        @if (Model.Breadcrumbs.Any())
        {
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb breadcrumb-style1 mb-0">
                    @for (var i = 0; i < Model.Breadcrumbs.Count; i++)
                    {
                        var item = Model.Breadcrumbs[i];
                        var isLast = i == Model.Breadcrumbs.Count - 1;

                        if (!string.IsNullOrWhiteSpace(item.Url) && !isLast)
                        {
                            <li class="breadcrumb-item">
                                <a href="@item.Url">@item.Text</a>
                            </li>
                        }
                        else
                        {
                            <li class="breadcrumb-item active">@item.Text</li>
                        }
                    }
                </ol>
            </nav>
        }

        <!-- Page Title + Action Buttons -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center py-3 mb-4">
            <div>
                <h4 class="fw-bold mb-0">@Model.Title</h4>
            </div>
            @if (Model.ActionButtons != null)
            {
                <div class="d-flex align-content-center flex-wrap gap-2 mt-3 mt-md-0">
                    @Model.ActionButtons
                </div>
            }
        </div>
    </div>
</div>