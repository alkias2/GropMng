@model GropMng.Web.Areas.Admin.Models.Common.AdminPageHeaderModel

<div class="row">
    <div class="col-12">
        <div class="d-flex align-items-center py-3 mb-4">
            <div>
                <h4 class="fw-bold mb-1">@Model.Title</h4>
                @if (Model.Breadcrumbs.Any())
                {
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-style1 mb-0">
                            @for (var i = 0; i < Model.Breadcrumbs.Count; i++)
                            {
                                var item = Model.Breadcrumbs[i];
                                var isLast = i == Model.Breadcrumbs.Count - 1;

                                if (!string.IsNullOrWhiteSpace(item.Url) && !isLast)
                                {
                                    <li class="breadcrumb-item">
                                        <a href="@item.Url">@item.Text</a>
                                    </li>
                                }
                                else
                                {
                                    <li class="breadcrumb-item active">@item.Text</li>
                                }
                            }
                        </ol>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>