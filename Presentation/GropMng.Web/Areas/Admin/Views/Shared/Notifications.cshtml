@{
    var success = TempData["SuccessMessage"]?.ToString();
    var error = TempData["ErrorMessage"]?.ToString();
    var warning = TempData["WarningMessage"]?.ToString();
    var info = TempData["InfoMessage"]?.ToString();
}

@if (!string.IsNullOrWhiteSpace(success))
{
    <script>
        (function () {
            var payload = { icon: 'success', title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(success)) };
            var show = function () {
                if (!window.GropSwal || typeof window.GropSwal.notify !== 'function')
                    return false;

                window.GropSwal.notify(payload);
                return true;
            };

            if (!show()) {
                window.addEventListener('load', function onLoad() {
                    show();
                }, { once: true });
            }
        })();
    </script>
}

