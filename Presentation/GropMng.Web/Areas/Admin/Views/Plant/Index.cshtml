@model GropMng.Web.Areas.Admin.Models.Plant.PlantSearchModel
@{
    ViewData["Title"] = T("admin.plant.title");
    ViewData["ActiveMenu"] = "Plants";

    var headerModel = new AdminPageHeaderModel
    {
        Title = T("admin.plant.title"),
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = T("common.dashboard"), Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = T("admin.plant.title") }
        }
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="d-flex justify-content-end mb-4">
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Plant" asp-action="Create">
        <i class="bx bx-plus me-1"></i> @T("admin.plant.create")
    </a>
</div>

<!-- Filter card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 me-auto">@T("common.filters")</h5>
        <button id="btnApplyFilters" class="btn btn-primary btn-sm">
            <i class="bx bx-filter-alt me-1"></i> @T("common.apply")
        </button>
        <button id="btnClearFilters" class="btn btn-outline-secondary btn-sm ms-2">
            <i class="bx bx-x me-1"></i> @T("common.clear")
        </button>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label" for="searchTermFilter">@T("common.search")</label>
                <input id="searchTermFilter" class="form-control" type="text" placeholder="@T("admin.plant.search.placeholder")" />
            </div>
            <div class="col-md-4">
                <label class="form-label" for="categoryFilter">@T("admin.plant.fields.category")</label>
                <select id="categoryFilter" class="form-select">
                    @foreach (var item in Model.AvailableCategories)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<partial name="Table" model="Model.GridModel" />

<form id="antiForgeryForm" method="post">
    @Html.AntiForgeryToken()
</form>

@section Vendors {
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
}

@section Scripts {
    <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
    <script src="~/js-custom/admin.table.js" asp-append-version="true"></script>
    <script src="~/js-custom/admin.grids/grid-plant.js" asp-append-version="true"></script>
    <script>
        'use strict';

        window.gropPlantGridConfig = {
            editUrl: '@Url.Action("Edit", "Plant", new { area = "Admin" })',
            deleteUrl: '@Url.Action("Delete", "Plant", new { area = "Admin" })',
            token: $('#antiForgeryForm input[name="__RequestVerificationToken"]').val(),
            edibleText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.flags.edible"))),
            medicinalText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.flags.medicinal"))),
            toxicText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.flags.toxic"))),
            noneText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.none"))),
            deleteTitleText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.delete.title"))),
            deleteConfirmText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.delete.confirm"))),
            deleteText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.delete"))),
            cancelText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("common.cancel"))),
            categoryTexts: {
                Shrub: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.shrub"))),
                Tree: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.tree"))),
                Climber: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.climber"))),
                Ornamental: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.ornamental"))),
                Edible: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.edible"))),
                Aromatic: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.aromatic"))),
                Succulent: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.succulent"))),
                Grass: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.grass"))),
                Fern: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.fern"))),
                Other: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("admin.plant.category.other")))
            }
        };

        $(document).ready(function () {
            const table = $('#plantsTable').DataTable();
            window.GropAdminTable.bindFilterButtons(table, {
                applyButtonSelector: '#btnApplyFilters',
                clearButtonSelector: '#btnClearFilters',
                clearCallback: function () {
                    $('#searchTermFilter').val('');
                    $('#categoryFilter').val('');
                }
            });
        });
    </script>
}

