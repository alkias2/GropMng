@model GropMng.Web.Areas.Admin.Models.Plant.PlantSearchModel
@using GropMng.Web.Areas.Admin.Models.Plant
@using GropMng.Web.Framework.Models.DataTables
@using Microsoft.AspNetCore.Routing
@{
    ViewData["Title"] = T("admin.plant.title");
    GropHtml.SetActiveMenuItemSystemName("Plants");

    var addPlantUrl = Url.Action("Create", "Plant", new { area = "Admin" })!;
    var headerModel = new AdminPageHeaderModel
    {
        Title = T("admin.plant.title"),
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = T("common.dashboard"), Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = T("admin.plant.title") }
        },
        ActionButtons = new Microsoft.AspNetCore.Html.HtmlString(
            "<a href=\"" + addPlantUrl + "\" class=\"btn btn-primary\"><i class=\"bx bx-plus me-1\"></i> " + T("admin.plant.create") + "</a>")
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

@Html.AntiForgeryToken()

<!-- Filter card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center">
        <h5 class="card-title mb-0 me-auto">@T("common.filters")</h5>
        <button id="btnApplyFilters" class="btn btn-primary btn-sm">
            <i class="bx bx-filter-alt me-1"></i> @T("common.apply")
        </button>
        <button id="btnClearFilters" class="btn btn-outline-secondary btn-sm ms-2">
            <i class="bx bx-x me-1"></i> @T("common.clear")
        </button>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-8 col-sm-6">
                <grop-label asp-for="SearchTerm" />
                <grop-editor asp-for="SearchTerm" />
            </div>
            <div class="col-md-4 col-sm-6">
                <grop-label asp-for="Category" />
                <grop-select asp-for="Category" asp-items="Model.AvailableCategories" />
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("Table", new GropDataTablesModel
{
    Name = "plantsTable",
    UrlRead = new GropDataUrl("PlantList", "Plant", new RouteValueDictionary(new { area = "Admin" })),
    UrlDelete = new GropDataUrl("Delete", "Plant", new RouteValueDictionary(new { area = "Admin" })),
    SearchButtonId = "btnApplyFilters",
    ClearButtonId = "btnClearFilters",
    Length = Model.PageSize,
    LengthMenu = [10, 25, 50, 100],
    Filters =
    [
        new GropFilterParameter(nameof(PlantSearchModel.SearchTerm)),
        new GropFilterParameter(nameof(PlantSearchModel.Category))
    ],
    ColumnCollection =
    [
        new GropColumnProperty("id")
        {
            Title = T("admin.plant.grid.id"),
            Width = "60px",
        },
        new GropColumnProperty("commonName")
        {
            Title = T("admin.plant.fields.commonname"),
        },
        new GropColumnProperty("scientificName")
        {
            Title = T("admin.plant.fields.scientificname"),
        },
        new GropColumnProperty("family")
        {
            Title = T("admin.plant.fields.family"),
            ClassName = "text-truncate",
        },
        new GropColumnProperty("categoryLocalized")
        {
            Title = T("admin.plant.fields.category"),
            Width = "140px",
            ClassName = GropColumnClassDefaults.NoWrap,
            Render = new RenderBadge("badge bg-label-primary"),
        },
        new GropColumnProperty("flagsSummary")
        {
            Title = T("admin.plant.grid.flags"),
            Orderable = false,
            Searchable = false,
            ClassName = GropColumnClassDefaults.NoWrap,
        },
        new GropColumnProperty("id")
        {
            Title = T("common.edit"),
            Width = "80px",
            ClassName = GropColumnClassDefaults.Button,
            Orderable = false,
            Searchable = false,
            Render = new RenderButtonEdit(new GropDataUrl("Edit", "Plant", new RouteValueDictionary(new { area = "Admin" }))),
        },
        new GropColumnProperty("id")
        {
            Title = T("common.delete"),
            Width = "80px",
            ClassName = GropColumnClassDefaults.Button,
            Orderable = false,
            Searchable = false,
            Render = new RenderButtonRemove(new GropDataUrl("Delete", "Plant", new RouteValueDictionary(new { area = "Admin" }))),
        }
    ]
})

@section Vendors {
    <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
    <link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
}

@section Scripts {
    <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
}

