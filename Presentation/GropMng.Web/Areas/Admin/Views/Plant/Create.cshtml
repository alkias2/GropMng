@using GropMng.Web.Framework.TagHelpers.Admin
@model GropMng.Web.Areas.Admin.Models.Plant.PlantModel
@{
    ViewData["Title"] = T("admin.plant.create");
    GropHtml.SetActiveMenuItemSystemName("Plants");

    var listUrl = Url.Action("List", "Plant", new { area = "Admin" })!;
}

<grop-admin-page-header
    title="@T("admin.plant.create")"
    breadcrumbs="@(new List<AdminBreadcrumbItemModel>
    {
        new() { Text = T("common.dashboard"), Url = Url.Action("Index", "Home", new { area = "" }) },
        new() { Text = T("admin.plant.title"), Url = listUrl },
        new() { Text = T("common.create") }
    })">
    <grop-header-button href="@listUrl"
                        text="@T("common.cancel")"
                        icon="bx bx-arrow-back"
                        css-class="btn btn-label-secondary" />
    <grop-header-button form="plantCreateForm"
                        type="submit"
                        text="@T("common.save")"
                        icon="bx bx-save"
                        css-class="btn btn-primary" />
</grop-admin-page-header>

@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form id="plantCreateForm" asp-area="Admin" asp-controller="Plant" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("_CreateOrUpdate", Model)
        </form>
    </div>
</div>

