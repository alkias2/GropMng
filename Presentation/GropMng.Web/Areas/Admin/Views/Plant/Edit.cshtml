@model GropMng.Web.Areas.Admin.Models.Plant.PlantModel
@{
    var editText = T("common.edit");
    var titleText = T("admin.plant.edit");
    var plantsText = T("admin.plant.title");
    var dashboardText = T("common.dashboard");
    var dangerZoneText = T("common.dangerzone");
    var deletePlantText = T("admin.plant.delete");
    var deleteConfirmText = T("admin.plant.delete.confirm");
    var cannotUndoText = T("common.delete.cannotundo");

    ViewData["Title"] = titleText;
    GropHtml.SetActiveMenuItemSystemName("Plants");

    var headerModel = new AdminPageHeaderModel
    {
        Title = $"{editText}: {Model.CommonName}",
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = dashboardText, Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = plantsText, Url = Url.Action("List", "Plant", new { area = "Admin" }) }, 
            new() { Text = editText }
        }
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Plant" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            @await Html.PartialAsync("_CreateOrUpdate", Model)
        </form>
    </div>
</div>

<div class="card mt-4 border-danger">
    <div class="card-header">
        <h5 class="card-title text-danger mb-0">@dangerZoneText</h5>
    </div>
    <div class="card-body d-flex justify-content-between align-items-center">
        <p class="mb-0">@deleteConfirmText @cannotUndoText</p>
        <form asp-area="Admin"
              asp-controller="Plant"
              asp-action="Delete"
              method="post"
              data-grop-delete="true">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bx bx-trash me-1"></i> @deletePlantText
            </button>
        </form>
    </div>
</div>

