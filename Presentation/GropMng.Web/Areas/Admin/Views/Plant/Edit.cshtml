@model GropMng.Web.Areas.Admin.Models.Plant.PlantModel
@{
    ViewData["Title"] = T("admin.plant.edit");
    GropHtml.SetActiveMenuItemSystemName("Plants");

    var listUrl = Url.Action("List", "Plant", new { area = "Admin" })!;
    var headerModel = new AdminPageHeaderModel
    {
        Title = $"{T("common.edit")}: {Model.CommonName}",
        Breadcrumbs = new List<AdminBreadcrumbItemModel>
        {
            new() { Text = T("common.dashboard"), Url = Url.Action("Index", "Home", new { area = "" }) },
            new() { Text = T("admin.plant.title"), Url = listUrl },
            new() { Text = T("common.edit") }
        },
        ActionButtons = new Microsoft.AspNetCore.Html.HtmlString(
            "<a href=\"" + listUrl + "\" class=\"btn btn-label-secondary\"><i class=\"bx bx-arrow-back me-1\"></i> " + T("common.cancel") + "</a>" +
            " <button type=\"submit\" form=\"plantEditForm\" class=\"btn btn-primary\"><i class=\"bx bx-save me-1\"></i> " + T("common.save") + "</button>")
    };
}

@await Html.PartialAsync("_AdminPageHeader", headerModel)
@await Html.PartialAsync("Notifications")

<div class="card">
    <div class="card-body">
        <form id="plantEditForm" asp-area="Admin" asp-controller="Plant" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            @await Html.PartialAsync("_CreateOrUpdate", Model)
        </form>
    </div>
</div>

<div class="card mt-4 border-danger">
    <div class="card-header">
        <h5 class="card-title text-danger mb-0">@T("common.dangerzone")</h5>
    </div>
    <div class="card-body d-flex justify-content-between align-items-center">
        <p class="mb-0">@T("admin.plant.delete.confirm") @T("common.delete.cannotundo")</p>
        <form asp-area="Admin"
              asp-controller="Plant"
              asp-action="Delete"
              method="post"
              data-grop-delete="true">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bx bx-trash me-1"></i> @T("admin.plant.delete")
            </button>
        </form>
    </div>
</div>

