@model GropMng.Web.Areas.Admin.Models.Pesticide.PesticideModel

@{
    var localizedPesticideTypes = Model.AvailablePesticideTypes
        .Select(item => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = item.Value,
            Text = string.IsNullOrWhiteSpace(item.Value)
                ? T("common.none")
                : T($"admin.pesticide.pesticidetype.{item.Value.ToLowerInvariant()}"),
            Selected = item.Selected
        })
        .ToList();

    var localizedApplicationMethods = Model.AvailableApplicationMethods
        .Select(item => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = item.Value,
            Text = string.IsNullOrWhiteSpace(item.Value)
                ? T("common.none")
                : T($"admin.pesticide.applicationmethod.{item.Value.ToLowerInvariant()}"),
            Selected = item.Selected
        })
        .ToList();
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-md-6">
        <grop-label asp-for="Name" />
        <grop-editor asp-for="Name" asp-required="true" />
        <span class="text-danger" asp-validation-for="Name"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="Brand" />
        <grop-editor asp-for="Brand" />
        <span class="text-danger" asp-validation-for="Brand"></span>
    </div>

    <div class="col-md-6">
        <grop-label asp-for="ActiveIngredient" />
        <grop-editor asp-for="ActiveIngredient" />
        <span class="text-danger" asp-validation-for="ActiveIngredient"></span>
    </div>

    <div class="col-md-3">
        <grop-label asp-for="PesticideType" />
        <grop-select asp-for="PesticideType" asp-items="localizedPesticideTypes" />
        <span class="text-danger" asp-validation-for="PesticideType"></span>
    </div>

    <div class="col-md-3">
        <grop-label asp-for="ApplicationMethod" />
        <grop-select asp-for="ApplicationMethod" asp-items="localizedApplicationMethods" />
        <span class="text-danger" asp-validation-for="ApplicationMethod"></span>
    </div>

    <div class="col-md-3">
        <grop-label asp-for="WithholdingDays" />
        <grop-editor asp-for="WithholdingDays" />
        <span class="text-danger" asp-validation-for="WithholdingDays"></span>
    </div>

    <div class="col-md-9 d-flex align-items-end">
        <div class="form-check form-switch mb-1">
            <input class="form-check-input" type="checkbox" asp-for="IsOrganic" />
            <grop-label asp-for="IsOrganic" css-class="form-check-label" />
        </div>
    </div>

    <div class="col-md-12">
        <grop-label asp-for="SafetyNotes" />
        <grop-textarea asp-for="SafetyNotes" asp-rows="2" />
        <span class="text-danger" asp-validation-for="SafetyNotes"></span>
    </div>

    <div class="col-md-12">
        <grop-label asp-for="Notes" />
        <grop-textarea asp-for="Notes" asp-rows="3" />
        <span class="text-danger" asp-validation-for="Notes"></span>
    </div>
</div>
